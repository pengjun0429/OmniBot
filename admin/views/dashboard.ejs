<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OmniBot 控制臺</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0f0f1a; color: #e0e0e0;
    }

    .top-bar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 20px 36px; border-bottom: 1px solid #232340;
    }
    .top-bar .logo { font-size: 22px; font-weight: 800; color: #fff; }
    .top-bar .logo span { color: #7c6ff0; }
    .top-bar .right { display: flex; align-items: center; gap: 16px; }
    .top-bar .right .status { font-size: 12px; color: #666; }
    .top-bar .right .status .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; margin-right: 4px; }
    .top-bar .right .status .dot.on { background: #4ade80; }
    .top-bar .right .status .dot.off { background: #ef4444; }
    .top-bar .right a { color: #7c6ff0; text-decoration: none; font-size: 13px; }
    .top-bar .right a:hover { text-decoration: underline; }

    .hero {
      text-align: center; padding: 60px 20px 40px;
    }
    .hero h1 { font-size: 28px; color: #fff; margin-bottom: 8px; }
    .hero p { color: #8888aa; font-size: 15px; }

    .server-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 12px; padding: 0 36px 40px; max-width: 1200px; margin: 0 auto;
    }
    .server-card {
      background: #16162a; border-radius: 12px; border: 1px solid #232340;
      padding: 16px; display: flex; align-items: center; gap: 14px;
      cursor: pointer; transition: all 0.15s; text-decoration: none;
    }
    .server-card:hover { border-color: #7c6ff0; background: #1a1a34; transform: translateY(-1px); }
    .server-card .icon {
      width: 48px; height: 48px; border-radius: 10px; background: #2a2a4a;
      display: flex; align-items: center; justify-content: center; font-size: 24px;
      flex-shrink: 0; overflow: hidden;
    }
    .server-card .icon img { width: 48px; height: 48px; border-radius: 10px; }
    .server-card .info { min-width: 0; flex: 1; }
    .server-card .info .name { font-size: 15px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .server-card .info .detail { font-size: 12px; color: #6666aa; margin-top: 2px; }
    .server-card .members { font-size: 12px; color: #555; }
    .empty-state { text-align: center; padding: 60px 20px; color: #555; }
  </style>
</head>
<body>
  <div class="top-bar">
    <div class="logo">Omni<span>Bot</span></div>
    <div class="right">
      <span class="status">
        <span class="dot <%= online ? 'on' : 'off' %>"></span>
        <%= online ? '連線中' : '離線' %> · <%= ping %>ms
      </span>
      <a href="/logs">📋 日誌</a>
      <a href="/cmd">⚡ 指令</a>
      <a href="/logout">登出</a>
    </div>
  </div>

  <div class="hero">
    <h1>選擇一個伺服器開始</h1>
    <p>OmniBot 正在 <%= guilds.length %> 個伺服器中服務 <%= totalUsers %> 位成員</p>
  </div>

  <% if (guilds.length === 0) { %>
    <div class="empty-state">
      <p>尚未加入任何伺服器</p>
      <p style="font-size:13px;margin-top:8px;">請先將 Bot 邀請到你的伺服器</p>
    </div>
  <% } else { %>
    <div class="server-grid">
      <% guilds.forEach(g => { %>
        <a href="/server/<%= g.id %>" class="server-card">
          <div class="icon"><%- g.icon %></div>
          <div class="info">
            <div class="name"><%= g.name %></div>
            <div class="detail">ID: <%= g.id %></div>
          </div>
          <div class="members"><%= g.memberCount %></div>
        </a>
      <% }); %>
    </div>
  <% } %>
</body>
</html>
