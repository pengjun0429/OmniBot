<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理後臺 - 儀表板</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #1a1a2e; color: #eee;
      display: flex; min-height: 100vh;
    }
    .sidebar {
      width: 240px; background: #16213e; padding: 24px;
      display: flex; flex-direction: column;
    }
    .sidebar h2 { font-size: 18px; margin-bottom: 24px; }
    .sidebar nav a {
      display: block; padding: 10px 14px; color: #aaa;
      text-decoration: none; border-radius: 8px; margin-bottom: 4px;
      transition: all 0.2s;
    }
    .sidebar nav a:hover, .sidebar nav a.active {
      background: #0f3460; color: #fff;
    }
    .sidebar .logout {
      margin-top: auto; color: #e94560; text-decoration: none;
      padding: 10px 14px; border-radius: 8px;
    }
    .sidebar .logout:hover { background: rgba(233,69,96,0.1); }
    .main { flex: 1; padding: 32px; }
    h1 { font-size: 28px; margin-bottom: 24px; }
    .stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card {
      background: #16213e; padding: 20px; border-radius: 12px;
      text-align: center;
    }
    .stat-card .number { font-size: 36px; font-weight: bold; color: #e94560; }
    .stat-card .label { font-size: 14px; color: #aaa; margin-top: 4px; }
    .collections { background: #16213e; border-radius: 12px; padding: 20px; }
    .collections h2 { margin-bottom: 16px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 12px 8px; border-bottom: 1px solid #333; }
    th { color: #aaa; font-size: 13px; text-transform: uppercase; }
    td a { color: #4fc3f7; text-decoration: none; }
    td a:hover { text-decoration: underline; }
    .error { color: #e94560; margin-bottom: 16px; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <h2>🤖 OmniBot 後臺</h2>
    <nav>
      <a href="/" class="active">📊 儀表板</a>
      <a href="/guilds">🛡️ 伺服器設定</a>
      <% collections.forEach(c => { %>
        <a href="/collection/<%= c.name %>">📁 <%= c.name %></a>
      <% }); %>
    </nav>
    <a href="/logout" class="logout">🚪 登出</a>
  </aside>
  <div class="main">
    <h1>📊 儀表板</h1>

    <% if (locals.error) { %>
      <div class="error">⚠️ <%= error %></div>
    <% } %>

    <div class="stats">
      <div class="stat-card">
        <div class="number"><%= totalCollections %></div>
        <div class="label">集合總數</div>
      </div>
      <div class="stat-card">
        <div class="number"><%= totalDocuments %></div>
        <div class="label">文件總數</div>
      </div>
    </div>

    <div class="collections">
      <h2>📂 資料集合</h2>
      <table>
        <thead>
          <tr><th>集合名稱</th><th>文件數量</th><th>操作</th></tr>
        </thead>
        <tbody>
          <% collections.forEach(c => { %>
            <tr>
              <td><a href="/collection/<%= c.name %>"><%= c.name %></a></td>
              <td><%= c.count %></td>
              <td><a href="/collection/<%= c.name %>">檢視</a></td>
            </tr>
          <% }); %>
          <% if (collections.length === 0) { %>
            <tr><td colspan="3" style="text-align:center;color:#666;">暫無資料</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
