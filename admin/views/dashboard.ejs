<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OmniBot 控制臺</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0f0f1a; color: #e0e0e0;
      display: flex; min-height: 100vh;
    }

    .sidebar {
      width: 220px; background: #16162a; padding: 28px 16px;
      display: flex; flex-direction: column; border-right: 1px solid #232340;
    }
    .sidebar .logo { font-size: 22px; font-weight: 800; margin-bottom: 32px; color: #fff; letter-spacing: -0.5px; }
    .sidebar .logo span { color: #7c6ff0; }
    .sidebar nav a {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px; color: #8888aa; text-decoration: none;
      border-radius: 10px; margin-bottom: 2px; font-size: 14px; transition: all 0.15s;
    }
    .sidebar nav a:hover, .sidebar nav a.active { background: #1e1e3a; color: #fff; }
    .sidebar nav a.active { background: #2a2a4a; }
    .sidebar .status-dot {
      width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 6px;
    }
    .sidebar .status-dot.online { background: #4ade80; box-shadow: 0 0 6px #4ade80; }
    .sidebar .status-dot.offline { background: #ef4444; }
    .sidebar .logout { margin-top: auto; color: #666; text-decoration: none; padding: 10px 14px; font-size: 13px; border-radius: 8px; }
    .sidebar .logout:hover { background: rgba(255,255,255,0.05); color: #ef4444; }

    .main { flex: 1; padding: 28px 36px; max-width: calc(100% - 220px); }

    .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; }
    .top-bar h1 { font-size: 26px; font-weight: 700; color: #fff; }
    .top-bar .time { color: #666; font-size: 13px; }

    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 14px; margin-bottom: 28px; }
    .stat-card {
      background: linear-gradient(135deg, #1a1a34, #16162a);
      padding: 20px; border-radius: 14px; border: 1px solid #232340;
    }
    .stat-card .num { font-size: 28px; font-weight: 700; color: #fff; }
    .stat-card .label { font-size: 12px; color: #6666aa; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
    .stat-card .sub { font-size: 11px; color: #555; margin-top: 2px; }

    .card {
      background: #16162a; border-radius: 14px; border: 1px solid #232340;
      padding: 20px; margin-bottom: 20px;
    }
    .card h2 { font-size: 16px; color: #fff; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .card h2 .badge {
      background: #2a2a4a; color: #8888cc; font-size: 11px; padding: 2px 10px;
      border-radius: 20px; font-weight: 400;
    }

    .cmd-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px; }
    .cmd-item {
      background: #1e1e3a; padding: 10px 14px; border-radius: 8px; font-size: 13px;
    }
    .cmd-item .name { color: #7c6ff0; font-weight: 600; }
    .cmd-item .desc { color: #7777aa; font-size: 11px; margin-top: 2px; }

    .server-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 10px; }
    .server-card {
      background: #1e1e3a; padding: 14px; border-radius: 10px; display: flex; align-items: center; gap: 12px;
    }
    .server-card .icon {
      width: 36px; height: 36px; border-radius: 8px; background: #2a2a4a;
      display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;
    }
    .server-card .info { min-width: 0; }
    .server-card .info .name { font-size: 14px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .server-card .info .detail { font-size: 11px; color: #6666aa; }
    .server-card .members { margin-left: auto; font-size: 12px; color: #8888aa; white-space: nowrap; }

    .empty-state { text-align: center; padding: 30px; color: #555; font-size: 14px; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="logo">Omni<span>Bot</span></div>
    <nav>
      <a href="/dashboard" class="active">
        <span class="status-dot <%= online ? 'online' : 'offline' %>"></span>
        控制臺
      </a>
      <a href="/logs">📋 日誌</a>
      <a href="/cmd">⚡ 指令</a>
      <a href="/settings">⚙️ 設定</a>
      <a href="/announce">📢 公告</a>
      <% guilds.forEach(g => { %>
        <a href="/guild/<%= g.id %>" style="font-size:12px;padding:6px 12px;" title="<%= g.name %>">🖥️ <%= g.name.length > 12 ? g.name.slice(0,12)+'..' : g.name %></a>
      <% }); %>
    </nav>
    <a href="/logout" class="logout">登出</a>
  </aside>

  <div class="main">
    <div class="top-bar">
      <h1>控制臺</h1>
      <div class="time">運行中</div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="num"><%= guilds.length %></div>
        <div class="label">伺服器</div>
      </div>
      <div class="stat-card">
        <div class="num"><%= totalUsers %></div>
        <div class="label">成員總數</div>
      </div>
      <div class="stat-card">
        <div class="num"><%= commands.length %></div>
        <div class="label">指令數量</div>
      </div>
      <div class="stat-card">
        <div class="num"><%= ping %><span style="font-size:14px;color:#666">ms</span></div>
        <div class="label">延遲</div>
      </div>
      <div class="stat-card">
        <div class="num"><%= uptimeFormatted %></div>
        <div class="label">運行時間</div>
        <div class="sub">Node <%= nodeVersion %></div>
      </div>
    </div>

    <div class="card">
      <h2>📋 所有指令 <span class="badge"><%= commands.length %> 個</span></h2>
      <div class="cmd-grid">
        <% commands.forEach(cmd => { %>
          <div class="cmd-item">
            <div class="name">/<%= cmd.name %></div>
            <div class="desc"><%= cmd.desc %></div>
          </div>
        <% }); %>
      </div>
    </div>

    <div class="card">
      <h2>🖥️ 已加入的伺服器 <span class="badge"><%= guilds.length %> 個</span></h2>
      <% if (guilds.length === 0) { %>
        <div class="empty-state">尚未加入任何伺服器</div>
      <% } else { %>
        <div class="server-list">
          <% guilds.forEach(g => { %>
            <div class="server-card">
              <div class="icon"><%- g.icon %></div>
              <div class="info">
                <div class="name"><%= g.name %></div>
                <div class="detail">ID: <%= g.id %></div>
              </div>
              <div class="members"><%= g.memberCount %> 人</div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <div class="card">
      <h2>📢 快速發送公告</h2>
      <form onsubmit="quickAnnounce(event)" style="display:flex;gap:8px;align-items:flex-start;">
        <select id="qChannel" style="flex-shrink:0;width:180px;padding:8px 12px;background:#1e1e3a;border:1px solid #333;border-radius:6px;color:#fff;font-size:13px;">
          <option value="">選擇頻道...</option>
        </select>
        <input id="qMessage" type="text" placeholder="輸入訊息..." style="flex:1;padding:8px 12px;background:#1e1e3a;border:1px solid #333;border-radius:6px;color:#fff;font-size:13px;" required>
        <button type="submit" style="padding:8px 20px;background:#7c6ff0;color:#fff;border:none;border-radius:6px;cursor:pointer;">發送</button>
      </form>
      <div id="qStatus" style="margin-top:8px;font-size:13px;"></div>
    </div>
  </div>
  <script>
    async function loadChannels() {
      const sel = document.getElementById('qChannel');
      const res = await fetch('/api/channels');
      const data = await res.json();
      data.forEach(g => {
        const group = document.createElement('optgroup');
        group.label = g.name;
        g.channels.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.id; opt.textContent = '#' + c.name;
          group.appendChild(opt);
        });
        sel.appendChild(group);
      });
    }
    loadChannels();
    async function quickAnnounce(e) {
      e.preventDefault();
      const channelId = document.getElementById('qChannel').value;
      const message = document.getElementById('qMessage').value.trim();
      if (!channelId || !message) return;
      const status = document.getElementById('qStatus');
      status.textContent = '發送中...'; status.style.color = '#aaa';
      const res = await fetch('/api/announce/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId, message }),
      });
      const data = await res.json();
      status.textContent = data.success ? '✅ 已發送' : '❌ 失敗';
      status.style.color = data.success ? '#4ade80' : '#ef4444';
      if (data.success) document.getElementById('qMessage').value = '';
    }
  </script>
</body>
</html>
