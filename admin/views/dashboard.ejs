<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OmniBot 控制臺</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif; background:#09090b; color:#e4e4e7; min-height:100vh; }
    body::before { content:''; position:fixed; top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(ellipse at 20% 30%, rgba(99,102,241,0.04) 0%, transparent 50%),radial-gradient(ellipse at 80% 70%, rgba(6,182,212,0.03) 0%, transparent 50%);pointer-events:none;z-index:0; }

    .nav { position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;padding:14px 40px;background:rgba(24,24,27,0.8);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.05); }
    .nav .logo { font-size:20px;font-weight:800;color:#fff;text-decoration:none;letter-spacing:-0.5px; }
    .nav .logo span { color:#6366f1; }
    .nav .right { display:flex;align-items:center;gap:16px; }
    .nav .right .status { font-size:12px;color:#71717a;display:flex;align-items:center;gap:4px; }
    .nav .right .status .dot { width:6px;height:6px;border-radius:50%; }
    .nav .right .status .dot.on { background:#22c55e;box-shadow:0 0 8px rgba(34,197,94,0.4); }
    .nav .right .status .dot.off { background:#ef4444;box-shadow:0 0 8px rgba(239,68,68,0.4); }
    .nav .right a { color:#a1a1aa;text-decoration:none;font-size:13px;font-weight:500;transition:color 0.15s; }
    .nav .right a:hover { color:#fff; }
    .nav .right .badge { display:flex;align-items:center;gap:8px;padding:4px 10px 4px 4px;background:rgba(255,255,255,0.04);border-radius:20px;font-size:13px;color:#d4d4d8; }
    .nav .right .badge img { width:22px;height:22px;border-radius:50%; }

    .hero { position:relative;z-index:1;text-align:center;padding:60px 20px 28px; }
    .hero .icon { width:72px;height:72px;margin:0 auto 16px;background:linear-gradient(135deg,rgba(99,102,241,0.15),rgba(6,182,212,0.1));border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:32px; }
    .hero h1 { font-size:26px;font-weight:700;color:#fff;margin-bottom:6px;letter-spacing:-0.3px; }
    .hero p { color:#71717a;font-size:14px;font-weight:400; }
    .hero p strong { color:#6366f1;font-weight:600; }

    .stats { position:relative;z-index:1;display:flex;gap:10px;justify-content:center;padding:0 40px 28px;max-width:700px;margin:0 auto; }
    .stat { flex:1;background:rgba(24,24,27,0.6);border:1px solid rgba(255,255,255,0.04);border-radius:10px;padding:14px 18px;text-align:center;backdrop-filter:blur(10px); }
    .stat .num { font-size:22px;font-weight:700;color:#fff; }
    .stat .label { font-size:11px;color:#71717a;margin-top:1px;text-transform:uppercase;letter-spacing:0.5px; }

    .grid { position:relative;z-index:1;display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:8px;padding:0 40px 40px;max-width:1100px;margin:0 auto; }
    .card { background:rgba(24,24,27,0.6);border:1px solid rgba(255,255,255,0.04);border-radius:10px;padding:12px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:all 0.15s;text-decoration:none;backdrop-filter:blur(10px); }
    .card:hover { border-color:rgba(99,102,241,0.3);background:rgba(30,30,35,0.8);transform:translateY(-1px);box-shadow:0 4px 16px rgba(0,0,0,0.3); }
    .card .icon { width:42px;height:42px;border-radius:8px;background:rgba(39,39,42,0.6);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0; }
    .card .icon img { width:42px;height:42px;border-radius:8px; }
    .card .info { min-width:0;flex:1; }
    .card .info .name { font-size:14px;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
    .card .info .id { font-size:11px;color:#52525b;margin-top:1px; }
    .card .count { font-size:12px;color:#52525b;font-weight:500;padding:3px 8px;background:rgba(255,255,255,0.03);border-radius:6px; }

    .empty { position:relative;z-index:1;text-align:center;padding:60px 20px;color:#52525b; }
  </style>
</head>
<body>
  <div class="nav">
    <div class="logo">Omni<span>Bot</span></div>
    <div class="right">
      <% if (locals.user) { %>
        <span class="badge">
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=32">
          <%= user.global_name || user.username %>
        </span>
      <% } %>
      <span class="status"><span class="dot <%= online ? 'on' : 'off' %>"></span><%= online ? '在線' : '離線' %></span>
      <a href="/logs">日誌</a>
      <a href="/analytics">分析</a>
      <a href="/privacy">隱私</a>
      <a href="/logout" style="color:#ef4444;">登出</a>
    </div>
  </div>

  <div class="hero">
    <div class="icon">⚡</div>
    <h1>選擇伺服器</h1>
    <p>正在服務 <strong><%= guilds.length %></strong> 個伺服器 · <strong><%= totalUsers.toLocaleString() %></strong> 位成員</p>
  </div>

  <div class="stats">
    <div class="stat"><div class="num"><%= guilds.length %></div><div class="label">伺服器</div></div>
    <div class="stat"><div class="num"><%= totalUsers.toLocaleString() %></div><div class="label">成員</div></div>
    <div class="stat"><div class="num"><%= ping %>ms</div><div class="label">延遲</div></div>
  </div>

  <% if (guilds.length === 0) { %>
    <div class="empty"><p style="font-size:18px;margin-bottom:6px;">📡</p><p>尚未加入任何伺服器</p></div>
  <% } else { %>
    <div class="grid">
      <% guilds.forEach(g => { %>
        <a href="/server/<%= g.id %>" class="card">
          <div class="icon"><%- g.icon %></div>
          <div class="info">
            <div class="name"><%= g.name %></div>
            <div class="id"><%= g.id %></div>
          </div>
          <div class="count"><%= g.memberCount %></div>
        </a>
      <% }); %>
    </div>
  <% } %>
</body>
</html>
