<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>數據分析 - OmniBot</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif; background:#0a0a14; color:#e0e0e0; min-height:100vh; }
    body::before { content:''; position:fixed; top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(ellipse at 30%20%,rgba(124,111,240,0.06)0%,transparent 50%),radial-gradient(ellipse at 70%80%,rgba(233,69,96,0.04)0%,transparent 50%);pointer-events:none;z-index:0; }
    .top-bar { position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;padding:16px 40px;background:rgba(12,12,24,0.8);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.06); }
    .top-bar .logo { font-size:20px;font-weight:800;color:#fff;text-decoration:none; }
    .top-bar .logo span { color:#7c6ff0; }
    .top-bar .right { display:flex;align-items:center;gap:20px; }
    .top-bar .right a { color:#8888cc;text-decoration:none;font-size:13px; }
    .top-bar .right a:hover { color:#fff; }
    .content { position:relative;z-index:1;padding:32px 40px;max-width:1200px;margin:0 auto; }
    h1 { font-size:24px;color:#fff;margin-bottom:4px; }
    .subtitle { color:#8888aa;font-size:13px;margin-bottom:24px; }
    .stats-row { display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap; }
    .stat-card { flex:1;min-width:150px;background:rgba(22,22,42,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:16px 20px;backdrop-filter:blur(10px); }
    .stat-card .num { font-size:24px;font-weight:700;color:#fff; }
    .stat-card .label { font-size:12px;color:#6666aa;margin-top:2px; }
    .charts-row { display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px; }
    .chart-box { background:rgba(22,22,42,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:20px;backdrop-filter:blur(10px); }
    .chart-box h3 { font-size:14px;color:#fff;margin-bottom:12px; }
    .chart-box canvas { max-height:250px; }
    .server-table { width:100%;border-collapse:collapse;font-size:13px; }
    .server-table th { text-align:left;padding:8px 12px;color:#8888aa;font-weight:500;border-bottom:1px solid rgba(255,255,255,0.06); }
    .server-table td { padding:8px 12px;border-bottom:1px solid rgba(255,255,255,0.03); }
    .server-table tr:hover td { background:rgba(255,255,255,0.02); }
  </style>
</head>
<body>
  <div class="top-bar">
    <a href="/dashboard" class="logo">Omni<span>Bot</span></a>
    <div class="right">
      <% if (locals.user) { %>
        <span style="display:flex;align-items:center;gap:6px;font-size:13px;color:#aaa;">
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=32" style="width:20px;height:20px;border-radius:50%;">
          <%= user.global_name || user.username %>
        </span>
      <% } %>
      <a href="/logs">日誌</a>
      <a href="/cmd">指令</a>
      <a href="/export">匯出</a>
      <a href="/dashboard">← 返回</a>
    </div>
  </div>
  <div class="content">
    <h1>📊 數據分析</h1>
    <div class="subtitle">OmniBot 目前服務概覽</div>

    <div class="stats-row">
      <div class="stat-card"><div class="num"><%= totalGuilds %></div><div class="label">伺服器</div></div>
      <div class="stat-card"><div class="num"><%= totalHumans.toLocaleString() %></div><div class="label">真人成員</div></div>
    </div>

    <div class="charts-row">
      <div class="chart-box">
        <h3>👥 各伺服器成員數</h3>
        <canvas id="memberChart"></canvas>
      </div>
      <div class="chart-box">
        <h3>🤖 真人 vs Bot</h3>
        <canvas id="humanChart"></canvas>
      </div>
    </div>

    <div class="chart-box" style="margin-bottom:24px;">
      <h3>🏆 發言排行榜（模擬數據）</h3>
      <p style="font-size:12px;color:#888;margin-bottom:12px;">連接 Google Sheets 後將顯示真實數據</p>
      <canvas id="topChart" style="max-height:200px;"></canvas>
    </div>

    <div class="chart-box">
      <h3>📋 伺服器列表</h3>
      <table class="server-table">
        <tr><th>名稱</th><th>成員</th><th>真人</th><th>Bot</th><th>頻道數</th><th>建立時間</th><th>擁有者</th></tr>
        <% guildData.forEach(g => { %>
        <tr>
          <td><%= g.name %></td>
          <td><%= g.total %></td>
          <td><%= g.humans %></td>
          <td><%= g.bots %></td>
          <td><%= g.channels %></td>
          <td><t:%= Math.floor(g.created) %>:R></td>
          <td><%= g.owner %></td>
        </tr>
        <% }); %>
      </table>
    </div>
  </div>
  <script>
    const colors = ['#7c6ff0','#e94560','#4ade80','#f59e0b','#3b82f6','#ec4899','#14b8a6','#f97316','#8b5cf6','#22d3ee'];

    new Chart(document.getElementById('memberChart'), {
      type: 'bar',
      data: {
        labels: <%= JSON.stringify(guildData.map(g => g.name)) %>,
        datasets: [{ label: '成員數', data: <%= JSON.stringify(guildData.map(g => g.total)) %>, backgroundColor: colors, borderRadius: 4 }]
      },
      options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.04)' } }, x: { grid: { display: false } } } }
    });

    new Chart(document.getElementById('humanChart'), {
      type: 'doughnut',
      data: {
        labels: <%= JSON.stringify(guildData.map(g => g.name)) %>,
        datasets: [{ data: <%= JSON.stringify(guildData.map(g => g.humans)) %>, backgroundColor: colors, borderWidth: 0 }]
      },
      options: { responsive: true, plugins: { legend: { position: 'right', labels: { color: '#888', font: { size: 11 } } } } }
    });

    new Chart(document.getElementById('topChart'), {
      type: 'bar',
      data: {
        labels: ['範例用戶1','範例用戶2','範例用戶3','範例用戶4','範例用戶5','範例用戶6','範例用戶7','範例用戶8','範例用戶9','範例用戶10'],
        datasets: [{ label: '訊息數', data: [423,387,352,298,245,201,178,154,123,98], backgroundColor: colors, borderRadius: 4 }]
      },
      options: { indexAxis: 'y', responsive: true, plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.04)' } }, y: { grid: { display: false } } } }
    });
  </script>
</body>
</html>
