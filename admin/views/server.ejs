    <script>
      document.getElementById('announceTitle')?.addEventListener('input', updatePreview);
      document.getElementById('announceMsg')?.addEventListener('input', updatePreview);
      document.getElementById('announceColor')?.addEventListener('input', updatePreview);
      function updatePreview() {
        const title = document.getElementById('announceTitle').value || '?��?標�?';
        const msg = document.getElementById('announceMsg').value || '?��??�容將顯示在?�裡';
        const color = document.getElementById('announceColor').value;
        document.getElementById('previewTitle').textContent = title;
        document.getElementById('previewContent').textContent = msg;
        document.getElementById('previewBox').style.borderLeftColor = color;
      }
      async function sendAnnounce(e) {
        if (e) e.preventDefault();
        const channelId = document.getElementById('announceChannel').value;
        const title = document.getElementById('announceTitle').value.trim() || '?�� ?��?';
        const msg = document.getElementById('announceMsg').value.trim();
        const color = document.getElementById('announceColor').value || '#7c6ff0';
        if (!channelId) { document.getElementById('announceStatus').textContent = '請選?�頻??; document.getElementById('announceStatus').className = 'status-msg err'; return; }
        if (!msg) { document.getElementById('announceStatus').textContent = '請輸?�內�?; document.getElementById('announceStatus').className = 'status-msg err'; return; }
        const status = document.getElementById('announceStatus');
        status.textContent = '?�送中...'; status.className = 'status-msg';
        const res = await fetch('/api/announce/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
          body: JSON.stringify({ channelId, title, message: msg, color }),
        });
        const data = await res.json();
        status.textContent = data.success ? '??已發?? : '??' + data.error;
        status.className = 'status-msg ' + (data.success ? 'ok' : 'err');
        if (data.success) { document.getElementById('announceMsg').value = ''; document.getElementById('announceTitle').value = ''; updatePreview(); }
      }
    </script>

