              <input type="text" id="announceTitle" placeholder="йқҳп•қ?еҡ—о«Ҝж’©?пҡ—оЁ–?з Қ?" style="width:100%;padding:10px 14px;background:rgba(12,12,24,0.6);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:#e0e0e0;font-size:13px;">
            </div>
