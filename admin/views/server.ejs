    </div>
    <script>
      function updateWelcomePreview() {
        const msg = document.getElementById('welcomeMsg')?.value || '';
        const img = document.getElementById('welcomeImg')?.value || '';
        const preview = document.getElementById('welcomePreviewText');
        if (preview) {
          let text = msg.replace(/{mention}/g, '@ж’ оҗІ?').replace(/{user}/g, 'ж’ оҗІ?#1234').replace(/{server}/g, '?пҒ№ЛҠ?вҲӘжң«зҳЈйӨҢ???).replace(/{count}/g, '42').replace(/{channel}/g, '#з”ҮвҲҹ?').replace(/{role}/g, '@йҠқВҖ?зҘҶ???);
          preview.innerHTML = text.replace(/\n/g, '<br>');
        }
      }
    </script>

