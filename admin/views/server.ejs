  <script>
    async function sendTicketPanel(e) {
      e.preventDefault();
      const channelId = document.getElementById('ticketPanelChannel').value;
      if (!channelId) return;
      const status = document.getElementById('ticketPanelStatus');
      status.textContent = '?жҪ®ВҖојәи‘ү...'; status.className = 'status-msg';
      const res = await fetch('/api/server/<%= guild.id %>/send-ticket-panel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId }),
      });
      const data = await res.json();
      status.textContent = data.success ? '???пјёоІЎж’Ңи„©оЁӘ?? : '??' + data.error;
      status.className = 'status-msg ' + (data.success ? 'ok' : 'err');
    }

    async function sendPanel(e) {
      e.preventDefault();
      const channelId = document.getElementById('panelChannel').value;
      if (!channelId) return;
      const status = document.getElementById('panelStatus');
      status.textContent = '?жҪ®ВҖојәи‘ү...'; status.className = 'status-msg';
      const res = await fetch('/api/server/<%= guild.id %>/send-panel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId }),
      });
      const data = await res.json();
      status.textContent = data.success ? '???пјёоІЎж’Ңи„©оЁӘ?? : '??' + data.error;
      status.className = 'status-msg ' + (data.success ? 'ok' : 'err');
    }

    function switchTab(name, e) {
      if (e) e.preventDefault();
      document.querySelectorAll('.tabs a').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
      document.querySelector(`.tabs a[onclick*="'${name}'"]`).classList.add('active');
      document.getElementById('tab-' + name).classList.add('active');
      window.location.hash = name;
    }

    function applyPreset(val) {
      if (!val) return;
      const presets = {
        strict: { jt: 5, jw: 10, st: 5, sw: 5, tm: 5 },
        medium: { jt: 15, jw: 10, st: 10, sw: 8, tm: 10 },
        standard: { jt: 30, jw: 20, st: 15, sw: 15, tm: 30 },
      };
      const p = presets[val];
      if (p) {
        document.getElementById('joinThreshold').value = p.jt;
        document.getElementById('joinWindow').value = p.jw;
        document.getElementById('spamThreshold').value = p.st;
        document.getElementById('spamWindow').value = p.sw;
        document.getElementById('spamTimeout').value = p.tm;
      }
    }

    window.addEventListener('DOMContentLoaded', () => {
      const hash = window.location.hash.replace('#', '');
      if (hash) switchTab(hash);
    });
  </script>
