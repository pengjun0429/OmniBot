      <a href="#" onclick="switchTab('ticket', event)">?оҚҡ ж’ҢдәҷоЎ…</a>
      <a href="#" onclick="switchTab('automod', event)">?? ?иҠё?ж’–жӢҮо№ұ</a>
      <a href="#" onclick="switchTab('rolegive', event)">?? ?зҘҮ?зҳЈжӣ„оЁӘ</a>
      <a href="#" onclick="switchTab('inviteguard', event)">?? ???иқһвҲ ?</a>
      <a href="#" onclick="switchTab('appeal', event)">?? ?е”ҫиҝ„</a>
      <a href="#" onclick="switchTab('antiraid', event)">?оӘі ?и„°???/a>
      <a href="#" onclick="switchTab('invitelog', event)">?? ?ВҖйҡўп• и•ӯй ©?/a>
      <a href="#" onclick="switchTab('messagelog', event)">?? й–®оҰә??дәҘ?</a>
    <% } %>
    <a href="#" onclick="switchTab('announce', event)">?оҷў ?з Қ?</a>
  </div>

  <div class="tab-content">
    <div class="tab-pane active" id="tab-welcome">
      <div class="card">
        <h2>?? з”ҮвҲҹ?й–®п“Ғој…</h2>
