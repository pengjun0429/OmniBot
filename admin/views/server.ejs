<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - OmniBot</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #0a0a14;
      color: #e0e0e0;
      min-height: 100vh;
    }
    body::before {
      content: '';
      position: fixed;
      top: -50%; left: -50%;
      width: 200%; height: 200%;
      background: radial-gradient(ellipse at 30% 20%, rgba(124, 111, 240, 0.06) 0%, transparent 50%),
                  radial-gradient(ellipse at 70% 80%, rgba(233, 69, 96, 0.04) 0%, transparent 50%);
      pointer-events: none; z-index: 0;
    }

    .top-bar {
      position: relative; z-index: 1;
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px 40px;
      background: rgba(12, 12, 24, 0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .top-bar .logo { font-size: 20px; font-weight: 800; color: #fff; text-decoration: none; letter-spacing: -0.5px; }
    .top-bar .logo span { color: #7c6ff0; }
    .top-bar .right { display: flex; align-items: center; gap: 20px; }
    .top-bar .right a { color: #8888cc; text-decoration: none; font-size: 13px; font-weight: 500; transition: color 0.15s; }
    .top-bar .right a:hover { color: #fff; }
    .top-bar .right .user-badge {
      display: flex; align-items: center; gap: 8px;
      padding: 4px 10px 4px 4px;
      background: rgba(255,255,255,0.05);
      border-radius: 20px;
      font-size: 13px; color: #ccc;
    }
    .top-bar .right .user-badge img { width: 22px; height: 22px; border-radius: 50%; }
    .top-bar .right .role-badge {
      font-size: 11px; padding: 2px 8px; border-radius: 20px;
      font-weight: 600;
    }
    .top-bar .right .role-badge.top { background: rgba(124, 111, 240, 0.2); color: #7c6ff0; }
    .top-bar .right .role-badge.mod { background: rgba(255, 255, 255, 0.08); color: #888; }

    .guild-header {
      position: relative; z-index: 1;
      display: flex; align-items: center; gap: 20px;
      padding: 24px 40px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .guild-header .icon {
      width: 52px; height: 52px; border-radius: 14px; overflow: hidden; flex-shrink: 0;
      background: rgba(42, 42, 74, 0.6);
    }
    .guild-header .icon img { width: 52px; height: 52px; border-radius: 14px; }
    .guild-header .info { flex: 1; }
    .guild-header .info h1 { font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -0.3px; }
    .guild-header .info .meta { font-size: 12px; color: #5555aa; margin-top: 2px; }
    .guild-header .stats { display: flex; gap: 16px; }
    .guild-header .stats .stat { text-align: center; padding: 8px 16px; background: rgba(255,255,255,0.03); border-radius: 10px; }
    .guild-header .stats .stat .num { font-size: 18px; font-weight: 700; color: #fff; }
    .guild-header .stats .stat .label { font-size: 11px; color: #5555aa; margin-top: 1px; }

    .tabs {
      position: relative; z-index: 1;
      display: flex; gap: 0; padding: 0 40px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      overflow-x: auto;
    }
    .tabs a {
      padding: 12px 18px; color: #6666aa; text-decoration: none;
      font-size: 13px; font-weight: 500; border-bottom: 2px solid transparent;
      transition: all 0.15s; white-space: nowrap;
    }
    .tabs a:hover { color: #ccc; }
    .tabs a.active { color: #7c6ff0; border-bottom-color: #7c6ff0; }

    .tab-content { position: relative; z-index: 1; padding: 24px 40px; max-width: 960px; }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; }

    .card {
      background: rgba(22, 22, 42, 0.6);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px; padding: 24px; margin-bottom: 16px;
      backdrop-filter: blur(10px);
    }
    .card h2 { font-size: 16px; font-weight: 600; color: #fff; margin-bottom: 16px; letter-spacing: -0.2px; }

    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 12px; font-weight: 500; color: #8888cc; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.3px; }
    .form-group select, .form-group textarea, .form-group input[type="number"], .form-group input[type="text"] {
      width: 100%; padding: 10px 14px;
      background: rgba(12, 12, 24, 0.6);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px; color: #e0e0e0; font-size: 13px;
      transition: border-color 0.15s;
    }
    .form-group select:focus, .form-group textarea:focus, .form-group input:focus { outline: none; border-color: rgba(124, 111, 240, 0.5); }
    .form-group textarea { min-height: 60px; resize: vertical; }
    .form-group .hint { font-size: 11px; color: #5555aa; margin-top: 3px; }
    .form-group.checkbox {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px;
      background: rgba(12, 12, 24, 0.4);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 8px;
    }
    .form-group.checkbox label { margin: 0; cursor: pointer; text-transform: none; letter-spacing: 0; font-size: 13px; color: #ccc; }
    .form-group.checkbox input[type="checkbox"] { width: auto; accent-color: #7c6ff0; }

    .btn {
      background: linear-gradient(135deg, #7c6ff0, #6a5de0);
      color: #fff; border: none; padding: 10px 24px; border-radius: 8px;
      cursor: pointer; font-size: 13px; font-weight: 600;
      transition: all 0.15s; letter-spacing: 0.2px;
    }
    .btn:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(124, 111, 240, 0.3); }
    .btn-sm { padding: 7px 16px; font-size: 12px; }

    .role-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 6px; max-height: 300px; overflow-y: auto;
      background: rgba(12, 12, 24, 0.4); padding: 12px; border-radius: 10px; margin-bottom: 12px;
    }
    .role-item {
      display: flex; align-items: center; gap: 8px;
      padding: 6px 8px; border-radius: 6px; cursor: pointer; font-size: 13px;
      transition: background 0.1s;
    }
    .role-item:hover { background: rgba(255,255,255,0.04); }
    .role-item input { width: auto; accent-color: #7c6ff0; }

    .channel-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 6px;
    }
    .channel-item {
      background: rgba(12, 12, 24, 0.4); padding: 8px 12px; border-radius: 8px;
      font-size: 12px; color: #8888aa; border: 1px solid rgba(255,255,255,0.04);
    }

    .status-msg { font-size: 12px; margin-top: 6px; font-weight: 500; }
    .status-msg.ok { color: #4ade80; }
    .status-msg.err { color: #ef4444; }
  </style>
</head>
<body>
  <div class="top-bar">
    <a href="/dashboard" class="logo">Omni<span>Bot</span></a>
    <div class="right">
      <% if (locals.user) { %>
        <span class="user-badge">
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=32">
          <%= user.global_name || user.username %>
          <span class="role-badge <%= adminLevel %>"><%= adminLevel === 'top' ? '管理員' : '管理員' %></span>
        </span>
      <% } %>
      <a href="/logs">日誌</a>
      <a href="/cmd">指令</a>
      <a href="/privacy">隱私</a>
      <a href="/appeal" target="_blank" style="color:#f59e0b;">申訴</a>
      <a href="/logout" style="color:#e94560;">登出</a>
    </div>
  </div>

  <div class="guild-header">
    <div class="icon"><% if (guild.icon) { %><img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=48" alt=""><% } else { %>🌐<% } %></div>
    <div class="info">
      <h1><%= guild.name %></h1>
      <div class="meta">ID: <%= guild.id %> · 擁有者: <%= guild.ownerTag %></div>
    </div>
    <div class="stats">
      <div class="stat"><div class="num"><%= guild.memberCount %></div><div class="label">成員</div></div>
      <div class="stat"><div class="num"><%= guild.channels.length %></div><div class="label">頻道</div></div>
      <div class="stat"><div class="num"><%= guild.roleCount || 0 %></div><div class="label">身分組</div></div>
    </div>
  </div>

  <div class="tabs">
    <a href="#" class="active" onclick="switchTab('channels', event)">📁 頻道</a>
    <% if (adminLevel === 'top') { %>
      <a href="#" onclick="switchTab('welcome', event)">👋 歡迎</a>
      <a href="#" onclick="switchTab('farewell', event)">👋 告別</a>
      <a href="#" onclick="switchTab('roles', event)">🎭 身分組</a>
      <a href="#" onclick="switchTab('voice', event)">🔊 語音包房</a>
      <a href="#" onclick="switchTab('ticket', event)">🎫 工單</a>
      <a href="#" onclick="switchTab('automod', event)">🤖 自動審核</a>
      <a href="#" onclick="switchTab('rolegive', event)">🎁 公開派發</a>
      <a href="#" onclick="switchTab('inviteguard', event)">🔗 連結管理</a>
      <a href="#" onclick="switchTab('appeal', event)">📋 申訴</a>
      <a href="#" onclick="switchTab('antiraid', event)">🚨 防轟炸</a>
      <a href="#" onclick="switchTab('messagelog', event)">📝 記錄日誌</a>
    <% } %>
    <a href="#" onclick="switchTab('announce', event)">📢 公告</a>
  </div>

  <div class="tab-content">
    <div class="tab-pane active" id="tab-welcome">
      <div class="card">
        <h2>👋 歡迎訊息</h2>
        <form method="POST" action="/api/settings/<%= guild.id %>">
          <input type="hidden" name="type" value="welcome">
          <input type="hidden" name="_tab" value="welcome">
          <div class="form-group">
            <label>發送頻道</label>
            <select name="channelId">
              <option value="">不啟用</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.welcome.channelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>訊息內容</label>
            <textarea name="message" placeholder='哈囉 {mention}，歡迎來到 {server}！\n👋 目前伺服器總人數：{count}人\n請先去 {channel} | 領取身分組 {role}\n祝你聊天愉快！'><%= guild.welcome.message %></textarea>
            <div class="hint"><code>{mention}</code> = @提及 · <code>{user}</code> = 成員名稱 · <code>{server}</code> = 伺服器名稱 · <code>{count}</code> = 成員數 · <code>{channel}</code> = 頻道連結 · <code>{role}</code> = 身分組連結</div>
          </div>
          <div class="form-group checkbox">
            <input type="checkbox" name="enabled" value="1" <%= guild.welcome.enabled ? 'checked' : '' %>>
            <label>啟用歡迎訊息</label>
          </div>
          <div class="form-group">
            <label>歡迎圖片 URL（選填）</label>
            <input type="text" name="image" value="<%= guild.welcome.image || '' %>" placeholder="貼上圖片網址" style="width:100%;padding:10px 14px;background:rgba(12,12,24,0.6);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:#e0e0e0;font-size:13px;">
            <div class="hint">貼上圖片網址，歡迎訊息底部會顯示大圖</div>
          </div>
          <button type="submit" class="btn">儲存</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-farewell">
      <div class="card">
        <h2>👋 告別訊息</h2>
        <form method="POST" action="/api/settings/<%= guild.id %>">
          <input type="hidden" name="type" value="farewell">
          <input type="hidden" name="_tab" value="farewell">
          <div class="form-group">
            <label>發送頻道</label>
            <select name="channelId">
              <option value="">不啟用</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.farewell.channelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>訊息內容</label>
            <textarea name="message" placeholder='例如：{mention} 離開了 {server}'><%= guild.farewell.message %></textarea>
            <div class="hint"><code>{mention}</code> = @提及 · <code>{user}</code> = 成員名稱 · <code>{server}</code> = 伺服器名稱</div>
          </div>
          <div class="form-group checkbox">
            <input type="checkbox" name="enabled" value="1" <%= guild.farewell.enabled ? 'checked' : '' %>>
            <label>啟用告別訊息</label>
          </div>
          <button type="submit" class="btn">儲存</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-roles">
      <div class="card">
        <h2>🎭 自助領取身分組</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          勾選以下身分組，成員在 Discord 輸入 <code>/role</code> 即可自行領取/移除
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/roles">
          <div class="role-grid">
            <% guild.roles.forEach(r => { %>
              <label class="role-item">
                <input type="checkbox" name="roles" value="<%= r.id %>" <%= guild.selfRoles.includes(r.id) ? 'checked' : '' %>>
                <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:<%= r.color %>;"></span>
                <%= r.name %>
              </label>
            <% }); %>
          </div>
          <button type="submit" class="btn">儲存身分組設定</button>
        </form>

        <div style="margin-top:20px;padding-top:20px;border-top:1px solid #232340;">
          <h2 style="font-size:16px;color:#fff;margin-bottom:12px;">📨 發送身分組領取面板</h2>
          <p style="font-size:13px;color:#888;margin-bottom:12px;">
            選擇要發送的頻道，Bot 會發送一個永久按鈕面板，成員點擊按鈕即可領取/移除身分組
          </p>
          <form onsubmit="sendPanel(event)" style="display:flex;gap:8px;align-items:flex-start;">
            <select id="panelChannel" style="width:220px;padding:8px 12px;background:#1e1e3a;border:1px solid #333;border-radius:6px;color:#fff;font-size:13px;">
              <option value="">選擇頻道...</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>">#<%= c.name %></option>
              <% }); %>
            </select>
            <button type="submit" class="btn">發送面板</button>
          </form>
          <div id="panelStatus" class="status-msg" style="margin-top:8px;font-size:13px;"></div>
        </div>
      </div>
    </div>

    <div class="tab-pane" id="tab-announce">
      <div class="card">
        <h2>📢 發送公告</h2>
        <p style="font-size:13px;color:#888;margin-bottom:16px;">
          選擇頻道並輸入內容，Bot 會以 Embed 格式發送公告。
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div>
            <div class="form-group">
              <label>發送頻道</label>
              <select id="announceChannel">
                <option value="">選擇頻道...</option>
                <% guild.channels.forEach(c => { %>
                  <option value="<%= c.id %>">#<%= c.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label>公告標題（選填）</label>
              <input type="text" id="announceTitle" placeholder="例如：伺服器公告" style="width:100%;padding:10px 14px;background:rgba(12,12,24,0.6);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:#e0e0e0;font-size:13px;">
            </div>
            <div class="form-group">
              <label>公告內容</label>
              <textarea id="announceMsg" placeholder="輸入公告內容..." rows="5" style="width:100%;padding:10px 14px;background:rgba(12,12,24,0.6);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:#e0e0e0;font-size:13px;resize:vertical;"></textarea>
            </div>
            <div class="form-group">
              <label>顏色（選填）</label>
              <input type="color" id="announceColor" value="#7c6ff0" style="width:60px;height:36px;border:none;border-radius:6px;cursor:pointer;background:transparent;">
            </div>
            <button onclick="sendAnnounce(event)" class="btn" style="margin-top:4px;">📨 發送公告</button>
            <div id="announceStatus" class="status-msg" style="margin-top:8px;"></div>
          </div>
          <div>
            <div style="background:rgba(22,22,42,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:16px;">
              <div style="font-size:11px;color:#666;margin-bottom:8px;">預覽</div>
              <div id="previewBox" style="background:rgba(12,12,24,0.6);border-radius:8px;padding:16px;border-left:4px solid #7c6ff0;">
                <div id="previewTitle" style="font-size:15px;font-weight:600;color:#fff;margin-bottom:6px;">公告標題</div>
                <div id="previewContent" style="font-size:13px;color:#ccc;line-height:1.6;">公告內容將顯示在這裡</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script>
      document.getElementById('announceTitle')?.addEventListener('input', updatePreview);
      document.getElementById('announceMsg')?.addEventListener('input', updatePreview);
      document.getElementById('announceColor')?.addEventListener('input', updatePreview);
      function updatePreview() {
        const title = document.getElementById('announceTitle').value || '公告標題';
        const msg = document.getElementById('announceMsg').value || '公告內容將顯示在這裡';
        const color = document.getElementById('announceColor').value;
        document.getElementById('previewTitle').textContent = title;
        document.getElementById('previewContent').textContent = msg;
        document.getElementById('previewBox').style.borderLeftColor = color;
      }
      async function sendAnnounce(e) {
        if (e) e.preventDefault();
        const channelId = document.getElementById('announceChannel').value;
        const title = document.getElementById('announceTitle').value.trim() || '📢 公告';
        const msg = document.getElementById('announceMsg').value.trim();
        const color = document.getElementById('announceColor').value || '#7c6ff0';
        if (!channelId) { document.getElementById('announceStatus').textContent = '請選擇頻道'; document.getElementById('announceStatus').className = 'status-msg err'; return; }
        if (!msg) { document.getElementById('announceStatus').textContent = '請輸入內容'; document.getElementById('announceStatus').className = 'status-msg err'; return; }
        const status = document.getElementById('announceStatus');
        status.textContent = '發送中...'; status.className = 'status-msg';
        const res = await fetch('/api/announce/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ channelId, title, message: msg, color }),
        });
        const data = await res.json();
        status.textContent = data.success ? '✅ 已發送' : '❌ ' + data.error;
        status.className = 'status-msg ' + (data.success ? 'ok' : 'err');
        if (data.success) { document.getElementById('announceMsg').value = ''; document.getElementById('announceTitle').value = ''; updatePreview(); }
      }
    </script>

    <div class="tab-pane" id="tab-channels">
      <div class="card">
        <h2>📁 頻道列表 (<%= guild.channels.length %>)</h2>
        <div class="channel-grid">
          <% guild.channels.forEach(c => { %>
            <div class="channel-item">#<%= c.name %></div>
          <% }); %>
        </div>
      </div>
    </div>

    <div class="tab-pane" id="tab-voice">
      <div class="card">
        <h2>🔊 自動語音包房</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          設定一個語音頻道作為「創建頻道」，成員加入後 Bot 會自動創建專屬包房並轉移過去。<br>
          包房創建人可使用 <code>/voice</code> 指令管理（重新命名、鎖定、踢人、轉移所有權）。
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/autovoice">
          <div class="form-group">
            <label>創建頻道</label>
            <select name="channelId">
              <option value="">不啟用</option>
              <% guild.voiceChannels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.autoVoice.channelId === c.id ? 'selected' : '' %>>🔊 <%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>包房分類（選填，不選則跟創建頻道同一類別）</label>
            <select name="categoryId">
              <option value="">不指定</option>
              <% guild.categories.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.autoVoice.categoryId === c.id ? 'selected' : '' %>>📁 <%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn">儲存設定</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-ticket">
      <div class="card">
        <h2>🎫 工單系統</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          成員點擊「建立工單」按鈕後，Bot 會自動創建私人頻道，只有管理員和該成員看得到。
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/ticket">
          <div class="form-group">
            <label>工單分類（選填）</label>
            <select name="categoryId">
              <option value="">不指定</option>
              <% guild.categories.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.ticket.categoryId === c.id ? 'selected' : '' %>>📁 <%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>可查看工單的身分組（按住 Ctrl 選多個）</label>
            <select name="roleIds" multiple style="height:120px;">
              <% guild.roles.forEach(r => { %>
                <option value="<%= r.id %>" <%= guild.ticket.roleIds.includes(r.id) ? 'selected' : '' %>><%= r.name %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn">儲存設定</button>
        </form>
        <div style="margin-top:16px;padding-top:16px;border-top:1px solid #232340;">
          <p style="font-size:13px;color:#888;margin-bottom:8px;">發送開單面板到指定頻道：</p>
          <form onsubmit="sendTicketPanel(event)" style="display:flex;gap:8px;">
            <select id="ticketPanelChannel" style="width:220px;padding:8px 12px;background:#1e1e3a;border:1px solid #333;border-radius:6px;color:#fff;font-size:13px;">
              <option value="">選擇頻道...</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>">#<%= c.name %></option>
              <% }); %>
            </select>
            <button type="submit" class="btn">發送面板</button>
          </form>
          <div id="ticketPanelStatus" class="status-msg" style="margin-top:8px;font-size:13px;"></div>
        </div>
      </div>
    </div>

    <div class="tab-pane" id="tab-automod">
      <div class="card">
        <h2>🤖 自動審核</h2>
        <form method="POST" action="/api/settings/<%= guild.id %>/automod">
          <input type="hidden" name="_tab" value="automod">
          <div class="form-group checkbox">
            <input type="hidden" name="enabled" value="0">
            <input type="checkbox" name="enabled" value="1" <%= guild.autoMod.enabled ? 'checked' : '' %>>
            <label>啟用自動審核</label>
          </div>
          <div class="form-group">
            <label>過濾詞（用逗號分隔）</label>
            <textarea name="words" placeholder="例如：髒話1,髒話2,廣告詞"><%= (guild.autoMod.words || []).join(',') %></textarea>
          </div>
          <div class="form-group checkbox">
            <input type="hidden" name="blockLinks" value="0">
            <input type="checkbox" name="blockLinks" value="1" <%= guild.autoMod.blockLinks ? 'checked' : '' %>>
            <label>封鎖連結</label>
          </div>
          <div class="form-group">
            <label>違規懲罰</label>
            <select name="punishment">
              <option value="delete" <%= guild.autoMod.punishment === 'delete' ? 'selected' : '' %>>刪除訊息</option>
              <option value="timeout" <%= guild.autoMod.punishment === 'timeout' ? 'selected' : '' %>>刪除+禁言</option>
              <option value="kick" <%= guild.autoMod.punishment === 'kick' ? 'selected' : '' %>>刪除+踢出</option>
            </select>
          </div>
          <div class="form-group">
            <label>禁言分鐘（僅禁言有效）</label>
            <input type="number" name="timeoutMinutes" value="<%= guild.autoMod.timeoutMinutes || 10 %>" min="1" style="width:100px;">
          </div>
          <div class="form-group">
            <label>公告級別</label>
            <select name="logLevel">
              <option value="all" <%= guild.autoMod.logLevel === 'all' ? 'selected' : '' %>>全部紀錄</option>
              <option value="punish_only" <%= guild.autoMod.logLevel === 'punish_only' ? 'selected' : '' %>>僅懲罰紀錄</option>
              <option value="off" <%= guild.autoMod.logLevel === 'off' ? 'selected' : '' %>>不紀錄</option>
            </select>
          </div>
          <div class="form-group">
            <label>紀錄頻道</label>
            <select name="logChannelId">
              <option value="">不設定</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.autoMod.logChannelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div style="margin-top:16px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.06);">
            <h2 style="font-size:14px;color:#fff;margin-bottom:12px;">📊 累犯門檻</h2>
            <p style="font-size:12px;color:#888;margin-bottom:12px;">可設定每階段不同的懲罰方式和禁言時間</p>
            <% for (let i = 2; i <= 5; i++) {
              const s = guild.autoMod.strikes?.[i] || {};
              const action = typeof s === 'object' ? (s.action || '') : s;
              const dur = typeof s === 'object' ? (s.duration || guild.autoMod.timeoutMinutes || 10) : guild.autoMod.timeoutMinutes || 10;
            %>
            <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px;">
              <span style="font-size:13px;color:#aaa;width:120px;">第<%= i %>次違規</span>
              <select name="strike_action_<%= i %>" style="flex:1;padding:8px 12px;background:rgba(12,12,24,0.6);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:#e0e0e0;font-size:13px;">
                <option value="">跟前一次一樣</option>
                <option value="delete" <%= action === 'delete' ? 'selected' : '' %>>僅刪除</option>
                <option value="timeout" <%= action === 'timeout' ? 'selected' : '' %>>禁言</option>
                <option value="kick" <%= action === 'kick' ? 'selected' : '' %>>踢出</option>
              </select>
              <input type="number" name="strike_duration_<%= i %>" value="<%= dur %>" min="1" style="width:80px;padding:8px 12px;background:rgba(12,12,24,0.6);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:#e0e0e0;font-size:13px;" placeholder="分鐘">
              <span style="font-size:12px;color:#888;">分鐘</span>
            </div>
            <% } %>
            <div class="form-group" style="margin-top:12px;">
              <label>重置時間（小時）</label>
              <input type="number" name="strikeResetHours" value="<%= guild.autoMod.strikeResetHours || 24 %>" min="1" style="width:100px;">
            </div>
          </div>
          <button type="submit" class="btn" style="margin-top:16px;">儲存設定</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-rolegive">
      <div class="card">
        <h2>🎁 公開派發公告</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          使用 <code>/give @成員 @身分組</code> 派發身分組時，選擇一個頻道自動公告。
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/rolegive">
          <div class="form-group">
            <label>公告頻道（不選則只私訊不公告）</label>
            <select name="channelId">
              <option value="">不公告</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.roleGive.channelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn">儲存設定</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-inviteguard">
      <div class="card">
        <h2>🔗 邀請連結管理</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          啟用後非白名單的 Discord 邀請連結會自動刪除。
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/inviteguard">
          <div class="form-group checkbox">
            <input type="hidden" name="enabled" value="0">
            <input type="checkbox" name="enabled" value="1" <%= guild.inviteGuard.enabled ? 'checked' : '' %>>
            <label>啟用邀請過濾</label>
          </div>
          <div class="form-group">
            <label>白名單邀請碼（逗號分隔）</label>
            <textarea name="whitelist" placeholder="例如：abc123,def456"><%= (guild.inviteGuard.whitelist || []).join(',') %></textarea>
          </div>
          <div class="form-group">
            <label>日誌頻道</label>
            <select name="logChannelId">
              <option value="">不設定</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.inviteGuard.logChannelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn">儲存設定</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-appeal">
      <div class="card">
        <h2>📋 封禁申訴</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          使用者可到 <code>/appeal</code> 填寫申訴表單。<br>
          選擇一個頻道接收申訴通知。
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/appeal">
          <div class="form-group">
            <label>申訴通知頻道</label>
            <select name="channelId">
              <option value="">不啟用</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.appeal.channelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn">儲存設定</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-antiraid">
      <div class="card">
        <h2>🚨 防轟炸</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          偵測短時間大量加入或大量訊息，自動處理可疑活動。
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/antiraid">
          <div class="form-group checkbox">
            <input type="hidden" name="enabled" value="0">
            <input type="checkbox" name="enabled" value="1" <%= guild.antiRaid.enabled ? 'checked' : '' %>>
            <label>啟用防轟炸</label>
          </div>
          <div style="display:flex;gap:12px;">
            <div class="form-group" style="flex:1;">
              <label>大量加入門檻（次數）</label>
              <input type="number" name="joinThreshold" value="<%= guild.antiRaid.joinThreshold || 5 %>" min="2">
            </div>
            <div class="form-group" style="flex:1;">
              <label>時間範圍（秒）</label>
              <input type="number" name="joinWindow" value="<%= guild.antiRaid.joinWindow || 10 %>" min="3">
            </div>
          </div>
          <div style="display:flex;gap:12px;">
            <div class="form-group" style="flex:1;">
              <label>大量訊息門檻（則數）</label>
              <input type="number" name="spamThreshold" value="<%= guild.antiRaid.spamThreshold || 5 %>" min="3">
            </div>
            <div class="form-group" style="flex:1;">
              <label>時間範圍（秒）</label>
              <input type="number" name="spamWindow" value="<%= guild.antiRaid.spamWindow || 5 %>" min="3">
            </div>
            <div class="form-group" style="flex:1;">
              <label>禁言分鐘</label>
              <input type="number" name="spamTimeout" value="<%= guild.antiRaid.spamTimeout || 1 %>" min="1">
            </div>
          </div>
          <div class="form-group">
            <label>觸發動作</label>
            <select name="action">
              <option value="kick" <%= guild.antiRaid.action === 'kick' ? 'selected' : '' %>>踢出</option>
              <option value="log" <%= guild.antiRaid.action === 'log' ? 'selected' : '' %>>僅記錄</option>
            </select>
          </div>
          <div class="form-group">
            <label>日誌頻道</label>
            <select name="logChannelId">
              <option value="">不設定</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.antiRaid.logChannelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn">儲存設定</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-messagelog">
      <div class="card">
        <h2>🗑️ 編輯/刪除紀錄</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          設定一個頻道，Bot 會自動記錄成員的訊息編輯和刪除。
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/messagelog">
          <input type="hidden" name="_tab" value="messagelog">
          <div class="form-group">
            <label>紀錄頻道</label>
            <select name="channelId">
              <option value="">不啟用</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.messageLog.channelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn">儲存設定</button>
        </form>
      </div>
      <div class="card">
        <h2>📝 全部訊息紀錄 → Google Sheets</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          啟用後，所有成員的每則訊息會自動寫入 Google Sheets 的 MessageLog 工作表。<br>
          （需要先設定 <code>GOOGLE_DB_URL</code> 環境變數）
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/messagelog">
          <input type="hidden" name="_tab" value="messagelog">
          <div class="form-group checkbox">
            <input type="hidden" name="messageLogAllEnabled" value="0">
            <input type="checkbox" name="messageLogAllEnabled" value="1" <%= guild.messageLogAll.enabled ? 'checked' : '' %>>
            <label>啟用 Google Sheets 訊息紀錄</label>
          </div>
          <button type="submit" class="btn">儲存設定</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    async function sendTicketPanel(e) {
      e.preventDefault();
      const channelId = document.getElementById('ticketPanelChannel').value;
      if (!channelId) return;
      const status = document.getElementById('ticketPanelStatus');
      status.textContent = '發送中...'; status.className = 'status-msg';
      const res = await fetch('/api/server/<%= guild.id %>/send-ticket-panel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId }),
      });
      const data = await res.json();
      status.textContent = data.success ? '✅ 面板已發送' : '❌ ' + data.error;
      status.className = 'status-msg ' + (data.success ? 'ok' : 'err');
    }

    async function sendPanel(e) {
      e.preventDefault();
      const channelId = document.getElementById('panelChannel').value;
      if (!channelId) return;
      const status = document.getElementById('panelStatus');
      status.textContent = '發送中...'; status.className = 'status-msg';
      const res = await fetch('/api/server/<%= guild.id %>/send-panel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId }),
      });
      const data = await res.json();
      status.textContent = data.success ? '✅ 面板已發送' : '❌ ' + data.error;
      status.className = 'status-msg ' + (data.success ? 'ok' : 'err');
    }

    function switchTab(name, e) {
      if (e) e.preventDefault();
      document.querySelectorAll('.tabs a').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
      document.querySelector(`.tabs a[onclick*="'${name}'"]`).classList.add('active');
      document.getElementById('tab-' + name).classList.add('active');
      window.location.hash = name;
    }

    window.addEventListener('DOMContentLoaded', () => {
      const hash = window.location.hash.replace('#', '');
      if (hash) switchTab(hash);
    });
  </script>
</body>
</html>
