              <div style="font-size:11px;color:#666;margin-bottom:8px;">?�覽</div>
              <div id="previewBox" style="background:rgba(12,12,24,0.6);border-radius:8px;padding:16px;border-left:4px solid #7c6ff0;">
                <div id="previewTitle" style="font-size:15px;font-weight:600;color:#fff;margin-bottom:6px;">?��?標�?</div>
                <div id="previewContent" style="font-size:13px;color:#ccc;line-height:1.6;">?��??�容將顯示在?�裡</div>
