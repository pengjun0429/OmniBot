<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - OmniBot</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif; background:#09090b; color:#e4e4e7; min-height:100vh; }
    body::before { content:''; position:fixed; top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(ellipse at 20% 30%, rgba(99,102,241,0.04) 0%, transparent 50%),radial-gradient(ellipse at 80% 70%, rgba(6,182,212,0.03) 0%, transparent 50%);pointer-events:none;z-index:0; }

    .top-bar { position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;padding:14px 40px;background:rgba(24,24,27,0.8);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.05); }
    .top-bar .logo { font-size:20px;font-weight:800;color:#fff;text-decoration:none;letter-spacing:-0.5px; }
    .top-bar .logo span { color:#6366f1; }
    .top-bar .right { display:flex;align-items:center;gap:16px; }
    .top-bar .right a { color:#a1a1aa;text-decoration:none;font-size:13px;font-weight:500;transition:color 0.15s; }
    .top-bar .right a:hover { color:#fff; }
    .top-bar .right .badge { display:flex;align-items:center;gap:8px;padding:4px 10px 4px 4px;background:rgba(255,255,255,0.04);border-radius:20px;font-size:13px;color:#d4d4d8; }
    .top-bar .right .badge img { width:22px;height:22px;border-radius:50%; }
    .top-bar .right .role-tag { font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600; }
    .top-bar .right .role-tag.top { background:rgba(99,102,241,0.15);color:#818cf8; }
    .top-bar .right .role-tag.mod { background:rgba(255,255,255,0.04);color:#71717a; }

    .header, .guild-header { position:relative;z-index:1;display:flex;align-items:center;gap:16px;padding:20px 40px;border-bottom:1px solid rgba(255,255,255,0.05); }
    .header .icon, .guild-header .icon { width:48px;height:48px;border-radius:12px;overflow:hidden;flex-shrink:0;background:rgba(39,39,42,0.6); }
    .header .icon img, .guild-header .icon img { width:48px;height:48px;border-radius:12px; }
    .header .info, .guild-header .info { flex:1; }
    .header .info h1, .guild-header .info h1 { font-size:18px;font-weight:700;color:#fff;letter-spacing:-0.3px; }
    .header .info .meta, .guild-header .info .meta { font-size:11px;color:#52525b;margin-top:1px; }
    .header .stats, .guild-header .stats { display:flex;gap:10px; }
    .header .stats .s, .guild-header .stats .stat { text-align:center;padding:6px 14px;background:rgba(255,255,255,0.02);border-radius:8px; }
    .header .stats .s .num, .guild-header .stats .stat .num { font-size:16px;font-weight:700;color:#fff; }
    .header .stats .s .label, .guild-header .stats .stat .label { font-size:10px;color:#52525b;margin-top:1px;text-transform:uppercase;letter-spacing:0.5px; }

    .tabs { position:relative;z-index:1;display:flex;gap:0;padding:0 40px;border-bottom:1px solid rgba(255,255,255,0.05);overflow-x:auto; }
    .tabs a { padding:10px 16px;color:#52525b;text-decoration:none;font-size:12px;font-weight:500;border-bottom:2px solid transparent;transition:all 0.15s;white-space:nowrap; }
    .tabs a:hover { color:#d4d4d8; }
    .tabs a.active { color:#818cf8;border-bottom-color:#6366f1; }

    .tab-content { position:relative;z-index:1;padding:20px 40px;max-width:900px; }
    .tab-pane { display:none; }
    .tab-pane.active { display:block; }

    .card { background:rgba(24,24,27,0.6);border:1px solid rgba(255,255,255,0.04);border-radius:10px;padding:20px;margin-bottom:12px;backdrop-filter:blur(10px); }
    .card h2 { font-size:15px;font-weight:600;color:#fff;margin-bottom:14px;letter-spacing:-0.2px; }

    .field, .form-group { margin-bottom:12px; }
    .field label, .form-group label { display:block;font-size:11px;font-weight:500;color:#71717a;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.3px; }
    .field select, .field textarea, .field input[type="number"], .field input[type="text"],
    .form-group select, .form-group textarea, .form-group input[type="number"], .form-group input[type="text"] { width:100%;padding:8px 12px;background:rgba(12,12,14,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:6px;color:#e4e4e7;font-size:13px;transition:border-color 0.15s; }
    .field select:focus, .field textarea:focus, .field input:focus,
    .form-group select:focus, .form-group textarea:focus, .form-group input:focus { outline:none;border-color:rgba(99,102,241,0.4); }
    .field textarea, .form-group textarea { min-height:60px;resize:vertical; }
    .field .hint, .form-group .hint { font-size:10px;color:#52525b;margin-top:2px; }
    .field.checkbox, .form-group.checkbox { display:flex;align-items:center;gap:10px;padding:8px 12px;background:rgba(12,12,14,0.4);border:1px solid rgba(255,255,255,0.04);border-radius:6px; }
    .field.checkbox label, .form-group.checkbox label { margin:0;cursor:pointer;text-transform:none;letter-spacing:0;font-size:13px;color:#d4d4d8; }
    .field.checkbox input, .form-group.checkbox input[type="checkbox"] { width:auto;accent-color:#6366f1; }

    .btn { background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;border:none;padding:8px 20px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600;transition:all 0.15s; }
    .btn:hover { transform:translateY(-1px);box-shadow:0 3px 12px rgba(99,102,241,0.25); }
    .btn-sm { padding:6px 14px;font-size:11px; }

    .role-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:4px;max-height:260px;overflow-y:auto;background:rgba(12,12,14,0.4);padding:10px;border-radius:8px;margin-bottom:10px; }
    .role-item { display:flex;align-items:center;gap:6px;padding:4px 6px;border-radius:4px;cursor:pointer;font-size:12px;transition:background 0.1s; }
    .role-item:hover { background:rgba(255,255,255,0.03); }
    .role-item input { width:auto;accent-color:#6366f1; }

    .ch-grid, .channel-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:4px; }
    .ch-item, .channel-item { background:rgba(12,12,14,0.4);padding:6px 10px;border-radius:6px;font-size:11px;color:#71717a;border:1px solid rgba(255,255,255,0.03); }

    .say-form { display:flex;gap:8px;align-items:flex-start; }
    .say-form select { flex-shrink:0;width:200px;padding:8px 12px;background:rgba(12,12,14,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:6px;color:#e4e4e7;font-size:13px; }
    .say-form input { flex:1;padding:8px 12px;background:rgba(12,12,14,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:6px;color:#e4e4e7;font-size:13px; }

    .status-msg { font-size:11px;margin-top:4px;font-weight:500; }
    .status-msg.ok { color:#22c55e; }
    .status-msg.err { color:#ef4444; }
    hr { border:none;border-top:1px solid rgba(255,255,255,0.04);margin:16px 0; }
  </style>
</head>
