<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - OmniBot</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0f0f1a; color: #e0e0e0;
    }

    .top-bar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 20px 36px; border-bottom: 1px solid #232340;
    }
    .top-bar .logo { font-size: 22px; font-weight: 800; color: #fff; text-decoration: none; }
    .top-bar .logo span { color: #7c6ff0; }
    .top-bar .right { display: flex; align-items: center; gap: 16px; }
    .top-bar .right a { color: #8888aa; text-decoration: none; font-size: 13px; }
    .top-bar .right a:hover { color: #fff; }

    .guild-header {
      display: flex; align-items: center; gap: 16px;
      padding: 24px 36px; background: #16162a; border-bottom: 1px solid #232340;
    }
    .guild-header .icon {
      width: 48px; height: 48px; border-radius: 10px; overflow: hidden; flex-shrink: 0;
    }
    .guild-header .icon img { width: 48px; height: 48px; border-radius: 10px; }
    .guild-header .info { flex: 1; }
    .guild-header .info h1 { font-size: 20px; color: #fff; }
    .guild-header .info .meta { font-size: 12px; color: #6666aa; margin-top: 2px; }
    .guild-header .stats { display: flex; gap: 20px; }
    .guild-header .stats .stat { text-align: center; }
    .guild-header .stats .stat .num { font-size: 18px; font-weight: 600; color: #fff; }
    .guild-header .stats .stat .label { font-size: 11px; color: #6666aa; }

    .tabs {
      display: flex; gap: 0; padding: 0 36px; background: #12121e;
      border-bottom: 1px solid #232340;
    }
    .tabs a {
      padding: 12px 20px; color: #8888aa; text-decoration: none;
      font-size: 13px; border-bottom: 2px solid transparent; transition: all 0.15s;
    }
    .tabs a:hover { color: #fff; }
    .tabs a.active { color: #7c6ff0; border-bottom-color: #7c6ff0; }

    .tab-content { padding: 24px 36px; }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; }

    .card {
      background: #16162a; border-radius: 12px; border: 1px solid #232340;
      padding: 20px; margin-bottom: 16px;
    }
    .card h2 { font-size: 16px; color: #fff; margin-bottom: 16px; }

    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 12px; color: #8888aa; margin-bottom: 4px; }
    .form-group select, .form-group textarea, .form-group input {
      width: 100%; padding: 8px 12px; background: #1e1e3a; border: 1px solid #333;
      border-radius: 6px; color: #fff; font-size: 13px;
    }
    .form-group textarea { min-height: 60px; resize: vertical; }
    .form-group .hint { font-size: 11px; color: #555; margin-top: 2px; }
    .form-group.checkbox { display: flex; align-items: center; gap: 8px; }
    .form-group.checkbox label { margin: 0; cursor: pointer; }
    .form-group.checkbox input { width: auto; }

    .btn { background: #7c6ff0; color: #fff; border: none; padding: 8px 20px; border-radius: 6px; cursor: pointer; font-size: 13px; }
    .btn:hover { background: #6a5de0; }
    .btn-sm { padding: 6px 14px; font-size: 12px; }

    .role-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 6px; max-height: 300px; overflow-y: auto;
      background: #1e1e3a; padding: 10px; border-radius: 8px; margin-bottom: 12px;
    }
    .role-item {
      display: flex; align-items: center; gap: 8px;
      padding: 4px 6px; border-radius: 4px; cursor: pointer; font-size: 13px;
    }
    .role-item:hover { background: #2a2a4a; }
    .role-item input { width: auto; }

    .channel-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 6px;
    }
    .channel-item { background: #1e1e3a; padding: 6px 10px; border-radius: 6px; font-size: 12px; color: #aaa; }

    .say-form { display: flex; gap: 8px; align-items: flex-start; }
    .say-form select { flex-shrink: 0; width: 200px; padding: 8px 12px; background: #1e1e3a; border: 1px solid #333; border-radius: 6px; color: #fff; font-size: 13px; }
    .say-form input { flex: 1; padding: 8px 12px; background: #1e1e3a; border: 1px solid #333; border-radius: 6px; color: #fff; font-size: 13px; }

    .status-msg { font-size: 12px; margin-top: 6px; }
    .status-msg.ok { color: #4ade80; }
    .status-msg.err { color: #ef4444; }
  </style>
</head>
<body>
  <div class="top-bar">
    <a href="/dashboard" class="logo">Omni<span>Bot</span></a>
    <div class="right">
      <a href="/logs">📋 日誌</a>
      <a href="/cmd">⚡ 指令</a>
      <a href="/logout">登出</a>
    </div>
  </div>

  <div class="guild-header">
    <div class="icon"><% if (guild.icon) { %><img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=48" alt=""><% } else { %>🌐<% } %></div>
    <div class="info">
      <h1><%= guild.name %></h1>
      <div class="meta">ID: <%= guild.id %> · 擁有者: <%= guild.ownerTag %></div>
    </div>
    <div class="stats">
      <div class="stat"><div class="num"><%= guild.memberCount %></div><div class="label">成員</div></div>
      <div class="stat"><div class="num"><%= guild.channels.length %></div><div class="label">頻道</div></div>
      <div class="stat"><div class="num"><%= guild.roleCount || 0 %></div><div class="label">身分組</div></div>
    </div>
  </div>

  <div class="tabs">
    <a href="#" class="active" onclick="switchTab('welcome', event)">👋 歡迎</a>
    <a href="#" onclick="switchTab('farewell', event)">👋 告別</a>
    <a href="#" onclick="switchTab('roles', event)">🎭 身分組</a>
    <a href="#" onclick="switchTab('announce', event)">📢 公告</a>
    <a href="#" onclick="switchTab('channels', event)">📁 頻道</a>
  </div>

  <div class="tab-content">
    <div class="tab-pane active" id="tab-welcome">
      <div class="card">
        <h2>👋 歡迎訊息</h2>
        <form method="POST" action="/api/settings/<%= guild.id %>">
          <input type="hidden" name="type" value="welcome">
          <div class="form-group">
            <label>發送頻道</label>
            <select name="channelId">
              <option value="">不啟用</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.welcome.channelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>訊息內容</label>
            <textarea name="message" placeholder='例如：{mention} 歡迎來到 {server}！'><%= guild.welcome.message %></textarea>
            <div class="hint"><code>{mention}</code> = @提及 · <code>{user}</code> = 成員名稱 · <code>{server}</code> = 伺服器名稱</div>
          </div>
          <div class="form-group checkbox">
            <input type="checkbox" name="enabled" value="1" <%= guild.welcome.enabled ? 'checked' : '' %>>
            <label>啟用歡迎訊息</label>
          </div>
          <button type="submit" class="btn">儲存</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-farewell">
      <div class="card">
        <h2>👋 告別訊息</h2>
        <form method="POST" action="/api/settings/<%= guild.id %>">
          <input type="hidden" name="type" value="farewell">
          <div class="form-group">
            <label>發送頻道</label>
            <select name="channelId">
              <option value="">不啟用</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.farewell.channelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>訊息內容</label>
            <textarea name="message" placeholder='例如：{mention} 離開了 {server}'><%= guild.farewell.message %></textarea>
            <div class="hint"><code>{mention}</code> = @提及 · <code>{user}</code> = 成員名稱 · <code>{server}</code> = 伺服器名稱</div>
          </div>
          <div class="form-group checkbox">
            <input type="checkbox" name="enabled" value="1" <%= guild.farewell.enabled ? 'checked' : '' %>>
            <label>啟用告別訊息</label>
          </div>
          <button type="submit" class="btn">儲存</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-roles">
      <div class="card">
        <h2>🎭 自助領取身分組</h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          勾選以下身分組，成員在 Discord 輸入 <code>/role</code> 即可自行領取/移除
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/roles">
          <div class="role-grid">
            <% guild.roles.forEach(r => { %>
              <label class="role-item">
                <input type="checkbox" name="roles" value="<%= r.id %>" <%= guild.selfRoles.includes(r.id) ? 'checked' : '' %>>
                <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:<%= r.color %>;"></span>
                <%= r.name %>
              </label>
            <% }); %>
          </div>
          <button type="submit" class="btn">儲存身分組設定</button>
        </form>

        <div style="margin-top:20px;padding-top:20px;border-top:1px solid #232340;">
          <h2 style="font-size:16px;color:#fff;margin-bottom:12px;">📨 發送身分組領取面板</h2>
          <p style="font-size:13px;color:#888;margin-bottom:12px;">
            選擇要發送的頻道，Bot 會發送一個永久按鈕面板，成員點擊按鈕即可領取/移除身分組
          </p>
          <form onsubmit="sendPanel(event)" style="display:flex;gap:8px;align-items:flex-start;">
            <select id="panelChannel" style="width:220px;padding:8px 12px;background:#1e1e3a;border:1px solid #333;border-radius:6px;color:#fff;font-size:13px;">
              <option value="">選擇頻道...</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>">#<%= c.name %></option>
              <% }); %>
            </select>
            <button type="submit" class="btn">發送面板</button>
          </form>
          <div id="panelStatus" class="status-msg" style="margin-top:8px;font-size:13px;"></div>
        </div>
      </div>
    </div>

    <div class="tab-pane" id="tab-announce">
      <div class="card">
        <h2>📢 發送公告</h2>
        <form class="say-form" onsubmit="sendAnnounce(event)">
          <select id="announceChannel">
            <option value="">選擇頻道...</option>
            <% guild.channels.forEach(c => { %>
              <option value="<%= c.id %>">#<%= c.name %></option>
            <% }); %>
          </select>
          <input type="text" id="announceMsg" placeholder="輸入公告內容..." required>
          <button type="submit" class="btn">發送</button>
        </form>
        <div id="announceStatus" class="status-msg"></div>
      </div>
    </div>

    <div class="tab-pane" id="tab-channels">
      <div class="card">
        <h2>📁 頻道列表 (<%= guild.channels.length %>)</h2>
        <div class="channel-grid">
          <% guild.channels.forEach(c => { %>
            <div class="channel-item">#<%= c.name %></div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>

  <script>
    async function sendPanel(e) {
      e.preventDefault();
      const channelId = document.getElementById('panelChannel').value;
      if (!channelId) return;
      const status = document.getElementById('panelStatus');
      status.textContent = '發送中...'; status.className = 'status-msg';
      const res = await fetch('/api/server/<%= guild.id %>/send-panel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId }),
      });
      const data = await res.json();
      status.textContent = data.success ? '✅ 面板已發送' : '❌ ' + data.error;
      status.className = 'status-msg ' + (data.success ? 'ok' : 'err');
    }

    function switchTab(name, e) {
      if (e) e.preventDefault();
      document.querySelectorAll('.tabs a').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
      document.querySelector(`.tabs a[onclick*="'${name}'"]`).classList.add('active');
      document.getElementById('tab-' + name).classList.add('active');
    }

    async function sendAnnounce(e) {
      e.preventDefault();
      const channelId = document.getElementById('announceChannel').value;
      const message = document.getElementById('announceMsg').value.trim();
      if (!channelId || !message) return;
      const status = document.getElementById('announceStatus');
      status.textContent = '發送中...'; status.className = 'status-msg';
      const res = await fetch('/api/announce/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId, message }),
      });
      const data = await res.json();
      status.textContent = data.success ? '✅ 已發送' : '❌ ' + data.error;
      status.className = 'status-msg ' + (data.success ? 'ok' : 'err');
      if (data.success) document.getElementById('announceMsg').value = '';
    }
  </script>
</body>
</html>
