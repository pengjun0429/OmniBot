<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - OmniBot</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif; background:#09090b; color:#e4e4e7; min-height:100vh; }
    body::before { content:''; position:fixed; top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(ellipse at 20% 30%, rgba(99,102,241,0.04) 0%, transparent 50%),radial-gradient(ellipse at 80% 70%, rgba(6,182,212,0.03) 0%, transparent 50%);pointer-events:none;z-index:0; }

    .top-bar { position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;padding:14px 40px;background:rgba(24,24,27,0.8);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.05); }
    .top-bar .logo { font-size:20px;font-weight:800;color:#fff;text-decoration:none;letter-spacing:-0.5px; }
    .top-bar .logo span { color:#6366f1; }
    .top-bar .right { display:flex;align-items:center;gap:16px; }
    .top-bar .right a { color:#a1a1aa;text-decoration:none;font-size:13px;font-weight:500;transition:color 0.15s; }
    .top-bar .right a:hover { color:#fff; }
    .top-bar .right .badge { display:flex;align-items:center;gap:8px;padding:4px 10px 4px 4px;background:rgba(255,255,255,0.04);border-radius:20px;font-size:13px;color:#d4d4d8; }
    .top-bar .right .badge img { width:22px;height:22px;border-radius:50%; }
    .top-bar .right .role-tag { font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600; }
    .top-bar .right .role-tag.top { background:rgba(99,102,241,0.15);color:#818cf8; }
    .top-bar .right .role-tag.mod { background:rgba(255,255,255,0.04);color:#71717a; }

    .header, .guild-header { position:relative;z-index:1;display:flex;align-items:center;gap:16px;padding:20px 40px;border-bottom:1px solid rgba(255,255,255,0.05); }
    .header .icon, .guild-header .icon { width:48px;height:48px;border-radius:12px;overflow:hidden;flex-shrink:0;background:rgba(39,39,42,0.6); }
    .header .icon img, .guild-header .icon img { width:48px;height:48px;border-radius:12px; }
    .header .info, .guild-header .info { flex:1; }
    .header .info h1, .guild-header .info h1 { font-size:18px;font-weight:700;color:#fff;letter-spacing:-0.3px; }
    .header .info .meta, .guild-header .info .meta { font-size:11px;color:#52525b;margin-top:1px; }
    .header .stats, .guild-header .stats { display:flex;gap:10px; }
    .header .stats .s, .guild-header .stats .stat { text-align:center;padding:6px 14px;background:rgba(255,255,255,0.02);border-radius:8px; }
    .header .stats .s .num, .guild-header .stats .stat .num { font-size:16px;font-weight:700;color:#fff; }
    .header .stats .s .label, .guild-header .stats .stat .label { font-size:10px;color:#52525b;margin-top:1px;text-transform:uppercase;letter-spacing:0.5px; }

    .tabs { position:relative;z-index:1;display:flex;gap:0;padding:0 40px;border-bottom:1px solid rgba(255,255,255,0.05);overflow-x:auto; }
    .tabs a { padding:10px 16px;color:#52525b;text-decoration:none;font-size:12px;font-weight:500;border-bottom:2px solid transparent;transition:all 0.15s;white-space:nowrap; }
    .tabs a:hover { color:#d4d4d8; }
    .tabs a.active { color:#818cf8;border-bottom-color:#6366f1; }

    .tab-content { position:relative;z-index:1;padding:20px 40px;max-width:900px; }
    .tab-pane { display:none; }
    .tab-pane.active { display:block; }

    .card { background:rgba(24,24,27,0.6);border:1px solid rgba(255,255,255,0.04);border-radius:10px;padding:20px;margin-bottom:12px;backdrop-filter:blur(10px); }
    .card h2 { font-size:15px;font-weight:600;color:#fff;margin-bottom:14px;letter-spacing:-0.2px; }

    .field, .form-group { margin-bottom:12px; }
    .field label, .form-group label { display:block;font-size:11px;font-weight:500;color:#71717a;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.3px; }
    .field select, .field textarea, .field input[type="number"], .field input[type="text"],
    .form-group select, .form-group textarea, .form-group input[type="number"], .form-group input[type="text"] { width:100%;padding:8px 12px;background:rgba(12,12,14,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:6px;color:#e4e4e7;font-size:13px;transition:border-color 0.15s; }
    .field select:focus, .field textarea:focus, .field input:focus,
    .form-group select:focus, .form-group textarea:focus, .form-group input:focus { outline:none;border-color:rgba(99,102,241,0.4); }
    .field textarea, .form-group textarea { min-height:60px;resize:vertical; }
    .field .hint, .form-group .hint { font-size:10px;color:#52525b;margin-top:2px; }
    .field.checkbox, .form-group.checkbox { display:flex;align-items:center;gap:10px;padding:8px 12px;background:rgba(12,12,14,0.4);border:1px solid rgba(255,255,255,0.04);border-radius:6px; }
    .field.checkbox label, .form-group.checkbox label { margin:0;cursor:pointer;text-transform:none;letter-spacing:0;font-size:13px;color:#d4d4d8; }
    .field.checkbox input, .form-group.checkbox input[type="checkbox"] { width:auto;accent-color:#6366f1; }

    .btn { background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;border:none;padding:8px 20px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600;transition:all 0.15s; }
    .btn:hover { transform:translateY(-1px);box-shadow:0 3px 12px rgba(99,102,241,0.25); }
    .btn-sm { padding:6px 14px;font-size:11px; }

    .role-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:4px;max-height:260px;overflow-y:auto;background:rgba(12,12,14,0.4);padding:10px;border-radius:8px;margin-bottom:10px; }
    .role-item { display:flex;align-items:center;gap:6px;padding:4px 6px;border-radius:4px;cursor:pointer;font-size:12px;transition:background 0.1s; }
    .role-item:hover { background:rgba(255,255,255,0.03); }
    .role-item input { width:auto;accent-color:#6366f1; }

    .ch-grid, .channel-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:4px; }
    .ch-item, .channel-item { background:rgba(12,12,14,0.4);padding:6px 10px;border-radius:6px;font-size:11px;color:#71717a;border:1px solid rgba(255,255,255,0.03); }

    .say-form { display:flex;gap:8px;align-items:flex-start; }
    .say-form select { flex-shrink:0;width:200px;padding:8px 12px;background:rgba(12,12,14,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:6px;color:#e4e4e7;font-size:13px; }
    .say-form input { flex:1;padding:8px 12px;background:rgba(12,12,14,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:6px;color:#e4e4e7;font-size:13px; }

    .status-msg { font-size:11px;margin-top:4px;font-weight:500; }
    .status-msg.ok { color:#22c55e; }
    .status-msg.err { color:#ef4444; }
    hr { border:none;border-top:1px solid rgba(255,255,255,0.04);margin:16px 0; }
  </style>
</head>
<body>
  <div class="top-bar">
    <div style="display:flex;align-items:center;gap:12px;">
      <a href="/dashboard" class="logo">Omni<span>Bot</span></a>
      <div style="position:relative;display:inline-block;">
        <select onchange="if(this.value)window.location.href='/server/'+this.value" style="padding:6px 12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:#e0e0e0;font-size:13px;cursor:pointer;max-width:180px;">
          <option value="" disabled selected style="display:none;"><%= guild.name %></option>
          <% (userGuilds || []).forEach(g => { %>
            <option value="<%= g.id %>" <%= g.id === guild.id ? 'selected' : '' %>><%= g.name %></option>
          <% }); %>
        </select>
      </div>
    </div>
    <div class="right">
      <% if (locals.user) { %>
        <span class="user-badge">
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=32">
          <%= user.global_name || user.username %>
          <span class="role-badge <%= adminLevel %>"><%= adminLevel === 'top' ? 'з®Ўз??? : 'з®Ўз??? %></span>
        </span>
      <% } %>
      <a href="/logs">?Ҙи?</a>
      <a href="/cmd">?Үд»Ө</a>
      <a href="/privacy">?ұз?</a>
      <a href="/appeal" target="_blank" style="color:#f59e0b;">?іиЁҙ</a>
      <a href="/logout" style="color:#e94560;">?»еҮә</a>
    </div>
  </div>

  <div class="guild-header">
    <div class="icon"><% if (guild.icon) { %><img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=48" alt=""><% } else { %>??<% } %></div>
    <div class="info">
      <h1><%= guild.name %></h1>
      <div class="meta">ID: <%= guild.id %> В· ?Ғж??? <%= guild.ownerTag %></div>
    </div>
    <div class="stats">
      <div class="stat"><div class="num"><%= guild.memberCount %></div><div class="label">?җе“Ў</div></div>
      <div class="stat"><div class="num"><%= guild.channels.length %></div><div class="label">?»й?</div></div>
      <div class="stat"><div class="num"><%= guild.roles ? guild.roles.length : 0 %></div><div class="label">иә«е?зө?/div></div>
    </div>
  </div>

  <div class="tabs">
    <a href="#" class="active" onclick="switchTab('channels', event)">?? ?»й?</a>
    <% if (adminLevel === 'top') { %>
      <a href="#" onclick="switchTab('welcome', event)">?? жӯЎи?</a>
      <a href="#" onclick="switchTab('farewell', event)">?? ?ҠеҲҘ</a>
      <a href="#" onclick="switchTab('roles', event)">?Һӯ иә«е?зө?/a>
      <a href="#" onclick="switchTab('voice', event)">?? иӘһйҹі?…жҲҝ</a>
      <a href="#" onclick="switchTab('ticket', event)">?Һ« е·Ҙе–®</a>
      <a href="#" onclick="switchTab('automod', event)">?? ?Әе?еҜ©ж ё</a>
      <a href="#" onclick="switchTab('rolegive', event)">?? ?¬й?жҙҫзҷј</a>
      <a href="#" onclick="switchTab('inviteguard', event)">?? ???з®Ўз?</a>
      <a href="#" onclick="switchTab('appeal', event)">?? ?іиЁҙ</a>
      <a href="#" onclick="switchTab('githubwebhook', event)">?? GitHub</a>
      <a href="#" onclick="switchTab('antiraid', event)">?ҡЁ ?Іи???/a>
      <a href="#" onclick="switchTab('invitelog', event)">?? ?Җи«ӢиҝҪи№?/a>
      <a href="#" onclick="switchTab('messagelog', event)">?? иЁҳй??Ҙи?</a>
    <% } %>
    <a href="#" onclick="switchTab('announce', event)">?“ў ?¬е?</a>
  </div>

  <div class="tab-content">
    <div class="tab-pane active" id="tab-welcome">
      <div class="card">
        <h2>?? жӯЎи?иЁҠжҒҜ</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div>
            <form method="POST" action="/api/settings/<%= guild.id %>" id="welcomeForm">
              <input type="hidden" name="type" value="welcome">
              <input type="hidden" name="_tab" value="welcome">
              <div class="form-group">
                <label>?јйҖҒй »??/label>
                <select name="channelId" onchange="updateWelcomePreview()">
                  <option value="">дёҚе???/option>
                  <% guild.channels.forEach(c => { %>
                    <option value="<%= c.id %>" <%= guild.welcome.channelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="form-group">
                <label>иЁҠжҒҜ?§е®№</label>
                <textarea name="message" id="welcomeMsg" oninput="updateWelcomePreview()" placeholder='?Ҳе? {mention}пјҢжӯЎиҝҺд???{server}пјҒ\n?? ?®е?дјәж??ЁзёҪдәәж•ёпјҡ{count}дәә\nи«Ӣе???{channel} | ?ҳе?иә«е?зө?{role}\nзҘқд??ҠеӨ©?үеҝ«пј?><%= guild.welcome.message %></textarea>
                <div class="hint"><code>{mention}</code> = @?җе? В· <code>{user}</code> = ?җе“Ў?ҚзЁұ В· <code>{server}</code> = дјәж??Ёе?зЁ?В· <code>{count}</code> = ?җе“Ў??В· <code>{channel}</code> = ?»й???? В· <code>{role}</code> = иә«е?зө„йҖ??</div>
              </div>
              <div class="form-group checkbox">
                <input type="checkbox" name="enabled" value="1" <%= guild.welcome.enabled ? 'checked' : '' %>>
                <label>?ҹз”ЁжӯЎи?иЁҠжҒҜ</label>
              </div>
              <div class="form-group">
                <label>жӯЎи??–з? URL</label>
                <input type="text" name="image" id="welcomeImg" value="<%= guild.welcome.image || '' %>" oninput="updateWelcomePreview()" placeholder="иІјд??–з?з¶Іе?">
              </div>
              <button type="submit" class="btn">?Іе?</button>
            </form>
          </div>
          <div id="welcomePreview" style="background:#313338;border-radius:8px;padding:16px;min-height:200px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
            <div style="background:#2b2d31;border-radius:4px;padding:12px;border-left:4px solid #5865F2;">
              <div style="font-size:12px;color:#888;margin-bottom:4px;">?? жӯЎи?? е…Ҙдјәж???/div>
              <div id="welcomePreviewText" style="font-size:14px;color:#dbdee1;line-height:1.5;">?Ҳе? @е°Ҹж?пјҢжӯЎиҝҺд????ғйЈҪ?ЎеҘҪжҙ»з??Ғп?</div>
              <div style="font-size:11px;color:#888;margin-top:8px;">д»ҠеӨ© 00:00</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script>
      function updateWelcomePreview() {
        const msg = document.getElementById('welcomeMsg')?.value || '';
        const img = document.getElementById('welcomeImg')?.value || '';
        const preview = document.getElementById('welcomePreviewText');
        if (preview) {
          let text = msg.replace(/{mention}/g, '@е°Ҹж?').replace(/{user}/g, 'е°Ҹж?#1234').replace(/{server}/g, '?ғйЈҪ?ЎеҘҪжҙ»з???).replace(/{count}/g, '42').replace(/{channel}/g, '#жӯЎи?').replace(/{role}/g, '@дёҖ?¬ж???);
          preview.innerHTML = text.replace(/\n/g, '<br>');
        }
      }
    </script>

    <div class="tab-pane" id="tab-farewell">
      <div class="card">
        <h2>?? ?ҠеҲҘиЁҠжҒҜ</h2>
        <form method="POST" action="/api/settings/<%= guild.id %>">
              
              <input type="hidden" name="type" value="farewell">
          <input type="hidden" name="_tab" value="farewell">
          <div class="form-group">
            <label>?јйҖҒй »??/label>
            <select name="channelId">
              <option value="">дёҚе???/option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>" <%= guild.farewell.channelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>иЁҠжҒҜ?§е®№</label>
            <textarea name="message" placeholder='дҫӢе?пјҡ{mention} ?ўй?дә?{server}'><%= guild.farewell.message %></textarea>
            <div class="hint"><code>{mention}</code> = @?җе? В· <code>{user}</code> = ?җе“Ў?ҚзЁұ В· <code>{server}</code> = дјәж??Ёе?зЁ?/div>
          </div>
          <div class="form-group checkbox">
            <input type="checkbox" name="enabled" value="1" <%= guild.farewell.enabled ? 'checked' : '' %>>
            <label>?ҹз”Ё?ҠеҲҘиЁҠжҒҜ</label>
          </div>
          <button type="submit" class="btn">?Іе?</button>
        </form>
      </div>
    </div>

    <div class="tab-pane" id="tab-roles">
      <div class="card">
        <h2>?Һӯ ?ӘеҠ©?ҳе?иә«е?зө?/h2>
        <p style="font-size:13px;color:#888;margin-bottom:12px;">
          ?ҫйҒёд»Ҙд?иә«е?зө„п??җе“Ў??Discord ијёе…Ҙ <code>/role</code> ?іеҸҜ?Әи??ҳе?/з§»йҷӨ
        </p>
        <form method="POST" action="/api/settings/<%= guild.id %>/roles">
          
          <div class="role-grid">
            <% guild.roles.forEach(r => { %>
              <label class="role-item">
                <input type="checkbox" name="roles" value="<%= r.id %>" <%= guild.selfRoles.includes(r.id) ? 'checked' : '' %>>
                <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:<%= r.color %>;"></span>
                <%= r.name %>
              </label>
            <% }); %>
          </div>
          <button type="submit" class="btn">?Іе?иә«е?зө„иЁӯе®?/button>
        </form>

        <div style="margin-top:20px;padding-top:20px;border-top:1px solid #232340;">
          <h2 style="font-size:16px;color:#fff;margin-bottom:12px;">?“Ё ?јйҖҒиә«?Ҷз??ҳе??ўжқҝ</h2>
          <p style="font-size:13px;color:#888;margin-bottom:12px;">
            ?ёж?иҰҒзҷј?Ғз??»й?пјҢBot ?ғзҷј?Ғд??Ӣж°ёд№…ж??•йқў?ҝп??җе“Ўй»һж??үй??іеҸҜ?ҳе?/з§»йҷӨиә«е?зө?
          </p>
          <form onsubmit="sendPanel(event)" style="display:flex;gap:8px;align-items:flex-start;">
            <select id="panelChannel" style="width:220px;padding:8px 12px;background:#1e1e3a;border:1px solid #333;border-radius:6px;color:#fff;font-size:13px;">
              <option value="">?ёж??»й?...</option>
              <% guild.channels.forEach(c => { %>
                <option value="<%= c.id %>">#<%= c.name %></option>
              <% }); %>
            </select>
            <button type="submit" class="btn">?јйҖҒйқў??/button>
          </form>
          <div id="panelStatus" class="status-msg" style="margin-top:8px;font-size:13px;"></div>
        </div>
      </div>
    </div>

    <div class="tab-pane" id="tab-announce">
      <div class="card">
        <h2>?“ў ?јйҖҒе…¬??/h2>
        <p style="font-size:13px;color:#888;margin-bottom:16px;">
          ?ёж??»й?дёҰијё?Ҙе…§е®№п?Bot ?ғд»Ҙ Embed ?је??јйҖҒе…¬?ҠгҖ?
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div>
            <div class="form-group">
              <label>?јйҖҒй »??/label>
              <select id="announceChannel">
                <option value="">?ёж??»й?...</option>
                <% guild.channels.forEach(c => { %>
                  <option value="<%= c.id %>">#<%= c.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label>?¬е?жЁҷй?пјҲйҒёеЎ«п?</label>
              <input type="text" id="announceTitle" placeholder="дҫӢе?пјҡдјә?ҚеҷЁ?¬е?" style="width:100%;padding:10px 14px;background:rgba(12,12,24,0.6);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:#e0e0e0;font-size:13px;">
            </div>
            <div class="form-group">
              <label>?¬е??§е®№</label>
              <textarea id="announceMsg" placeholder="ијёе…Ҙ?¬е??§е®№..." rows="5" style="width:100%;padding:10px 14px;background:rgba(12,12,24,0.6);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:#e0e0e0;font-size:13px;resize:vertical;"></textarea>
            </div>
            <div class="form-group">
              <label>йЎҸиүІпјҲйҒёеЎ«п?</label>
              <input type="color" id="announceColor" value="#7c6ff0" style="width:60px;height:36px;border:none;border-radius:6px;cursor:pointer;background:transparent;">
            </div>
            <button onclick="sendAnnounce(event)" class="btn" style="margin-top:4px;">?“Ё ?јйҖҒе…¬??/button>
            <div id="announceStatus" class="status-msg" style="margin-top:8px;"></div>
          </div>
          <div>
            <div style="background:rgba(22,22,42,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:16px;">
              <div style="font-size:11px;color:#666;margin-bottom:8px;">?җиҰҪ</div>
              <div id="previewBox" style="background:rgba(12,12,24,0.6);border-radius:8px;padding:16px;border-left:4px solid #7c6ff0;">
                <div id="previewTitle" style="font-size:15px;font-weight:600;color:#fff;margin-bottom:6px;">?¬е?жЁҷй?</div>
                <div id="previewContent" style="font-size:13px;color:#ccc;line-height:1.6;">?¬е??§е®№е°ҮйЎҜзӨәеңЁ?ҷиЈЎ</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script>
      document.getElementById('announceTitle')?.addEventListener('input', updatePreview);
      document.getElementById('announceMsg')?.addEventListener('input', updatePreview);
      document.getElementById('announceColor')?.addEventListener('input', updatePreview);
      function updatePreview() {
        const title = document.getElementById('announceTitle').value || '?¬е?жЁҷй?';
        const msg = document.getElementById('announceMsg').value || '?¬е??§е®№е°ҮйЎҜзӨәеңЁ?ҷиЈЎ';
        const color = document.getElementById('announceColor').value;
        document.getElementById('previewTitle').textContent = title;
        document.getElementById('previewContent').textContent = msg;
        document.getElementById('previewBox').style.borderLeftColor = color;
      }
      async function sendAnnounce(e) {
        if (e) e.preventDefault();
        const channelId = document.getElementById('announceChannel').value;
        const title = document.getElementById('announceTitle').value.trim() || '?“ў ?¬е?';
        const msg = document.getElementById('announceMsg').value.trim();
        const color = document.getElementById('announceColor').value || '#7c6ff0';
        if (!channelId) { document.getElementById('announceStatus').textContent = 'и«ӢйҒё?Үй »??; document.getElementById('announceStatus').className = 'status-msg err'; return; }
        if (!msg) { document.getElementById('announceStatus').textContent = 'и«Ӣијё?Ҙе…§е®?; document.getElementById('announceStatus').className = 'status-msg err'; return; }
        const status = document.getElementById('announceStatus');
        status.textContent = '?јйҖҒдёӯ...'; status.className = 'status-msg';
        const res = await fetch('/api/announce/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
          body: JSON.stringify({ channelId, title, message: msg, color }),
        });
        const data = await res.json();
        status.textContent = data.success ? '??е·Ізҷј?? : '??' + data.error;
        status.className = 'status-msg ' + (data.success ? 'ok' : 'err');
        if (data.success) { document.getElementById('announceMsg').value = ''; document.getElementById('announceTitle').value = ''; updatePreview(); }
      }
    </script>

