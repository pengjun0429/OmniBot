<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OmniBot - 指令</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0f0f1a; color: #e0e0e0; display: flex; min-height: 100vh; }
    .sidebar { width: 200px; background: #16162a; padding: 24px 14px; display: flex; flex-direction: column; border-right: 1px solid #232340; }
    .sidebar .logo { font-size: 20px; font-weight: 800; margin-bottom: 28px; color: #fff; }
    .sidebar .logo span { color: #7c6ff0; }
    .sidebar nav a { display: block; padding: 8px 12px; color: #8888aa; text-decoration: none; border-radius: 8px; margin-bottom: 2px; font-size: 13px; }
    .sidebar nav a:hover { background: #1e1e3a; color: #fff; }
    .sidebar nav a.active { background: #2a2a4a; color: #fff; }
    .sidebar .logout { margin-top: auto; color: #666; text-decoration: none; padding: 8px 12px; font-size: 12px; }
    .main { flex: 1; padding: 28px 36px; }
    h1 { font-size: 24px; margin-bottom: 20px; color: #fff; }
    .search-box { width: 100%; padding: 10px 14px; background: #1e1e3a; border: 1px solid #333; border-radius: 8px; color: #fff; font-size: 14px; margin-bottom: 16px; }
    .cmd-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 8px; }
    .cmd-item { background: #16162a; padding: 14px; border-radius: 10px; border: 1px solid #232340; cursor: pointer; transition: 0.15s; }
    .cmd-item:hover { border-color: #7c6ff0; background: #1a1a34; }
    .cmd-item .name { color: #7c6ff0; font-weight: 600; font-size: 15px; }
    .cmd-item .desc { color: #7777aa; font-size: 12px; margin-top: 4px; }
    .cmd-item .options { color: #555; font-size: 11px; margin-top: 6px; }
    .cmd-detail { background: #16162a; border: 1px solid #7c6ff0; border-radius: 10px; padding: 20px; margin-top: 20px; display: none; }
    .cmd-detail h2 { color: #fff; margin-bottom: 8px; }
    .cmd-detail p { color: #aaa; font-size: 14px; margin-bottom: 12px; }
    .cmd-detail .opt-item { background: #1e1e3a; padding: 8px 12px; border-radius: 6px; margin-bottom: 4px; font-size: 13px; color: #ccc; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="logo">Omni<span>Bot</span></div>
    <nav>
      <a href="/">儀表板</a>
      <a href="/logs">📋 日誌</a>
      <a href="/cmd" class="active">⚡ 指令</a>
    </nav>
    <a href="/logout" class="logout">登出</a>
  </aside>
  <div class="main">
    <h1>⚡ 指令列表</h1>
    <input type="text" class="search-box" placeholder="搜尋指令..." oninput="filter(this.value)">
    <div class="cmd-grid">
      <% commands.forEach(cmd => { %>
        <div class="cmd-item" onclick="showDetail('<%= cmd.name %>')">
          <div class="name">/<%= cmd.name %></div>
          <div class="desc"><%= cmd.desc %></div>
        </div>
      <% }); %>
    </div>
    <div class="cmd-detail" id="detail"></div>
  </div>
  <script>
    async function showDetail(name) {
      const res = await fetch('/api/cmd/run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ command: name }),
      });
      const data = await res.json();
      const el = document.getElementById('detail');
      if (!data.success) { el.innerHTML = '<p style="color:#ef4444;">' + data.error + '</p>'; el.style.display = 'block'; return; }
      let html = '<h2>/' + data.data.name + '</h2><p>' + data.data.description + '</p>';
      if (data.data.options && data.data.options.length > 0) {
        html += '<h3 style="color:#aaa;font-size:14px;margin-bottom:6px;">參數</h3>';
        data.data.options.forEach(o => {
          html += '<div class="opt-item">' + o.name + (o.required ? ' <span style="color:#ef4444;">*必填</span>' : '') + ' — ' + o.description + '</div>';
        });
      } else {
        html += '<p style="color:#555;font-size:13px;">無參數</p>';
      }
      el.innerHTML = html;
      el.style.display = 'block';
    }
    function filter(val) {
      document.querySelectorAll('.cmd-item').forEach(el => {
        el.style.display = el.textContent.includes(val) ? '' : 'none';
      });
    }
  </script>
</body>
</html>
