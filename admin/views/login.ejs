<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理員登入</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #1a1a2e;
      display: flex; justify-content: center; align-items: center;
      height: 100vh; color: #eee;
    }
    .login-card {
      background: #16213e;
      padding: 40px; border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
      width: 360px;
    }
    h1 { text-align: center; margin-bottom: 24px; font-size: 24px; }
    .error { color: #e94560; text-align: center; margin-bottom: 16px; font-size: 14px; }
    .divider { text-align: center; margin: 16px 0; color: #555; font-size: 13px; }
    .btn-discord {
      display: block; width: 100%; padding: 12px;
      background: #5865F2; color: white; border: none;
      border-radius: 8px; font-size: 16px; cursor: pointer;
      text-align: center; text-decoration: none;
      transition: background 0.2s;
    }
    .btn-discord:hover { background: #4752C4; }
  </style>
</head>
<body>
  <div class="login-card">
    <h1>🔐 管理員登入</h1>
    <% if (locals.error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/login">
      <div style="margin-bottom:16px;">
        <label style="display:block;font-size:13px;color:#888;margin-bottom:4px;">帳號</label>
        <input type="text" name="username" required style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;border-radius:8px;color:#fff;font-size:14px;">
      </div>
      <div style="margin-bottom:20px;">
        <label style="display:block;font-size:13px;color:#888;margin-bottom:4px;">密碼</label>
        <input type="password" name="password" required style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;border-radius:8px;color:#fff;font-size:14px;">
      </div>
      <button type="submit" style="width:100%;padding:12px;background:#7c6ff0;color:#fff;border:none;border-radius:8px;font-size:16px;cursor:pointer;">登入</button>
    </form>
  </div>
</body>
</html>
