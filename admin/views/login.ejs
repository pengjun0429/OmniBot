<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理員登入</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #1a1a2e;
      display: flex; justify-content: center; align-items: center;
      height: 100vh; color: #eee;
    }
    .login-card {
      background: #16213e;
      padding: 40px; border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
      width: 360px;
    }
    h1 { text-align: center; margin-bottom: 24px; font-size: 24px; }
    .error { color: #e94560; text-align: center; margin-bottom: 16px; font-size: 14px; }
    .divider { text-align: center; margin: 16px 0; color: #555; font-size: 13px; }
    .btn-discord {
      display: block; width: 100%; padding: 12px;
      background: #5865F2; color: white; border: none;
      border-radius: 8px; font-size: 16px; cursor: pointer;
      text-align: center; text-decoration: none;
      transition: background 0.2s;
    }
    .btn-discord:hover { background: #4752C4; }
  </style>
</head>
<body>
  <div class="login-card">
    <h1>🔐 管理員登入</h1>
    <% if (locals.error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <a href="/auth/discord" class="btn-discord"> Discord 登入</a>
  </div>
</body>
</html>
