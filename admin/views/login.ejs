<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理員登入</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #1a1a2e;
      display: flex; justify-content: center; align-items: center;
      height: 100vh; color: #eee;
    }
    .login-card {
      background: #16213e;
      padding: 40px; border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
      width: 360px;
    }
    h1 { text-align: center; margin-bottom: 24px; font-size: 24px; }
    .form-group { margin-bottom: 16px; }
    label { display: block; margin-bottom: 6px; font-size: 14px; color: #aaa; }
    input {
      width: 100%; padding: 10px 14px;
      border: 1px solid #333; border-radius: 8px;
      background: #0f3460; color: #eee; font-size: 14px;
    }
    input:focus { outline: none; border-color: #e94560; }
    button {
      width: 100%; padding: 12px;
      background: #e94560; color: white; border: none;
      border-radius: 8px; font-size: 16px; cursor: pointer;
      margin-top: 8px; transition: background 0.2s;
    }
    button:hover { background: #c73650; }
    .error { color: #e94560; text-align: center; margin-bottom: 16px; font-size: 14px; }
  </style>
</head>
<body>
  <div class="login-card">
    <h1>🔐 管理員登入</h1>
    <% if (locals.error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/login">
      <div class="form-group">
        <label>帳號</label>
        <input type="text" name="username" required>
      </div>
      <div class="form-group">
        <label>密碼</label>
        <input type="password" name="password" required>
      </div>
      <button type="submit">登入</button>
    </form>
  </div>
</body>
</html>
