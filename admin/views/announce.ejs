<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OmniBot - 公告</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0f0f1a; color: #e0e0e0; display: flex; min-height: 100vh; }
    .sidebar { width: 200px; background: #16162a; padding: 24px 14px; display: flex; flex-direction: column; border-right: 1px solid #232340; }
    .sidebar .logo { font-size: 20px; font-weight: 800; margin-bottom: 28px; color: #fff; }
    .sidebar .logo span { color: #7c6ff0; }
    .sidebar nav a { display: block; padding: 8px 12px; color: #8888aa; text-decoration: none; border-radius: 8px; margin-bottom: 2px; font-size: 13px; }
    .sidebar nav a:hover { background: #1e1e3a; color: #fff; }
    .sidebar nav a.active { background: #2a2a4a; color: #fff; }
    .sidebar .logout { margin-top: auto; color: #666; text-decoration: none; padding: 8px 12px; font-size: 12px; }
    .main { flex: 1; padding: 28px 36px; }
    h1 { font-size: 24px; margin-bottom: 20px; color: #fff; }
    .card { background: #16162a; border-radius: 12px; border: 1px solid #232340; padding: 20px; margin-bottom: 20px; }
    .card h2 { font-size: 16px; color: #fff; margin-bottom: 16px; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 12px; color: #8888aa; margin-bottom: 4px; }
    .form-group textarea, .form-group input {
      width: 100%; padding: 8px 12px; background: #1e1e3a; border: 1px solid #333;
      border-radius: 6px; color: #fff; font-size: 13px;
    }
    .form-group textarea { min-height: 100px; resize: vertical; }
    .channel-list { max-height: 200px; overflow-y: auto; background: #1e1e3a; border-radius: 6px; padding: 8px; }
    .channel-item { display: flex; align-items: center; gap: 8px; padding: 4px 6px; font-size: 13px; border-radius: 4px; cursor: pointer; }
    .channel-item:hover { background: #2a2a4a; }
    .channel-item input { width: auto; }
    .btn { background: #7c6ff0; color: #fff; border: none; padding: 10px 24px; border-radius: 6px; cursor: pointer; font-size: 14px; }
    .btn:hover { background: #6a5de0; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .progress { margin-top: 16px; }
    .progress-bar { height: 6px; background: #1e1e3a; border-radius: 3px; margin-top: 8px; overflow: hidden; }
    .progress-fill { height: 100%; background: #7c6ff0; border-radius: 3px; transition: width 0.3s; }
    .result { margin-top: 12px; font-size: 13px; }
    .result.success { color: #4ade80; }
    .result.error { color: #ef4444; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="logo">Omni<span>Bot</span></div>
    <nav>
      <a href="/dashboard">儀表板</a>
      <a href="/logs">📋 日誌</a>
      <a href="/cmd">⚡ 指令</a>
      <a href="/settings">⚙️ 設定</a>
      <a href="/announce" class="active">📢 公告</a>
    </nav>
    <a href="/logout" class="logout">登出</a>
  </aside>
  <div class="main">
    <h1>📢 發送公告</h1>
    <div class="card">
      <h2>發送訊息到多個頻道</h2>
      <form id="announceForm">
        <div class="form-group">
          <label>選擇伺服器與頻道</label>
          <div class="channel-list">
            <% guilds.forEach(g => { %>
              <div style="font-size:12px;color:#8888aa;padding:4px 6px;margin-top:4px;">🖥️ <%= g.name %></div>
              <% g.channels.forEach(c => { %>
                <label class="channel-item">
                  <input type="checkbox" name="channels" value="<%= c.id %>">
                  #<%= c.name %>
                </label>
              <% }); %>
            <% }); %>
            <% if (guilds.length === 0) { %>
              <div style="color:#555;padding:12px;text-align:center;">沒有可用的頻道</div>
            <% } %>
          </div>
        </div>
        <div class="form-group">
          <label>訊息內容</label>
          <textarea id="message" placeholder="輸入要發送的公告內容..." required></textarea>
        </div>
        <button type="submit" class="btn" id="sendBtn">發送公告</button>
      </form>
      <div class="progress" id="progress" style="display:none;">
        <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
        <div class="result" id="result"></div>
      </div>
    </div>
  </div>
  <script>
    document.getElementById('announceForm').onsubmit = async (e) => {
      e.preventDefault();
      const channels = [...document.querySelectorAll('input[name="channels"]:checked')].map(c => c.value);
      const message = document.getElementById('message').value.trim();
      if (!channels.length || !message) return alert('請選擇至少一個頻道並輸入訊息');
      const btn = document.getElementById('sendBtn');
      btn.disabled = true; btn.textContent = '發送中...';
      const progress = document.getElementById('progress');
      progress.style.display = 'block';
      let sent = 0, failed = 0;
      for (let i = 0; i < channels.length; i++) {
        try {
          const res = await fetch('/api/announce/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ channelId: channels[i], message }),
          });
          const data = await res.json();
          if (data.success) sent++; else failed++;
        } catch { failed++; }
        document.getElementById('progressFill').style.width = ((i + 1) / channels.length * 100) + '%';
      }
      btn.disabled = false; btn.textContent = '發送公告';
      document.getElementById('result').className = 'result ' + (failed === 0 ? 'success' : '');
      document.getElementById('result').textContent = `✅ 完成！成功 ${sent} 個頻道` + (failed ? `，失敗 ${failed} 個` : '');
    };
  </script>
</body>
</html>
