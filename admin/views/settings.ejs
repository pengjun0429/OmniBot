<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OmniBot - 設定</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0f0f1a; color: #e0e0e0; display: flex; min-height: 100vh; }
    .sidebar { width: 200px; background: #16162a; padding: 24px 14px; display: flex; flex-direction: column; border-right: 1px solid #232340; }
    .sidebar .logo { font-size: 20px; font-weight: 800; margin-bottom: 28px; color: #fff; }
    .sidebar .logo span { color: #7c6ff0; }
    .sidebar nav a { display: block; padding: 8px 12px; color: #8888aa; text-decoration: none; border-radius: 8px; margin-bottom: 2px; font-size: 13px; }
    .sidebar nav a:hover { background: #1e1e3a; color: #fff; }
    .sidebar nav a.active { background: #2a2a4a; color: #fff; }
    .sidebar nav a.active { background: #2a2a4a; color: #fff; }
    .sidebar .logout { margin-top: auto; color: #666; text-decoration: none; padding: 8px 12px; font-size: 12px; }
    .main { flex: 1; padding: 28px 36px; }
    h1 { font-size: 24px; margin-bottom: 20px; color: #fff; }
    .guild-tabs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; }
    .guild-tab { background: #1e1e3a; padding: 8px 14px; border-radius: 8px; cursor: pointer; font-size: 13px; color: #8888aa; border: 1px solid transparent; }
    .guild-tab:hover { border-color: #444; }
    .guild-tab.active { border-color: #7c6ff0; color: #fff; background: #2a2a4a; }
    .card { background: #16162a; border-radius: 12px; border: 1px solid #232340; padding: 20px; margin-bottom: 20px; }
    .card h2 { font-size: 16px; color: #fff; margin-bottom: 16px; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 12px; color: #8888aa; margin-bottom: 4px; }
    .form-group input, .form-group textarea, .form-group select {
      width: 100%; padding: 8px 12px; background: #1e1e3a; border: 1px solid #333;
      border-radius: 6px; color: #fff; font-size: 13px;
    }
    .form-group textarea { min-height: 60px; resize: vertical; }
    .form-group .hint { font-size: 11px; color: #555; margin-top: 2px; }
    .form-group.checkbox { display: flex; align-items: center; gap: 8px; }
    .form-group.checkbox label { margin: 0; cursor: pointer; }
    .form-group.checkbox input { width: auto; }
    .btn { background: #7c6ff0; color: #fff; border: none; padding: 8px 20px; border-radius: 6px; cursor: pointer; font-size: 13px; }
    .btn:hover { background: #6a5de0; }
    .success { color: #4ade80; font-size: 13px; margin-top: 8px; }
    .guild-info { display: none; }
    .guild-info.active { display: block; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="logo">Omni<span>Bot</span></div>
    <nav>
      <a href="/dashboard">儀表板</a>
      <a href="/logs">📋 日誌</a>
      <a href="/cmd">⚡ 指令</a>
      <a href="/settings" class="active">⚙️ 設定</a>
      <a href="/announce">📢 公告</a>
    </nav>
    <a href="/logout" class="logout">登出</a>
  </aside>
  <div class="main">
    <h1>⚙️ 伺服器設定</h1>

    <div class="guild-tabs">
      <% guilds.forEach((g, i) => { %>
        <div class="guild-tab <%= i === 0 ? 'active' : '' %>" onclick="switchGuild(<%= i %>)">🖥️ <%= g.name.length > 16 ? g.name.slice(0,16)+'..' : g.name %></div>
      <% }); %>
    </div>

    <% guilds.forEach((g, i) => { %>
      <div class="guild-info <%= i === 0 ? 'active' : '' %>" id="guild-<%= i %>">
        <div class="card">
          <h2>👋 歡迎訊息設定 — <%= g.name %></h2>
          <form method="POST" action="/api/settings/<%= g.id %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="type" value="welcome">
            <div class="form-group">
              <label>頻道</label>
              <select name="channelId">
                <option value="">不啟用</option>
                <% g.channels.forEach(c => { %>
                  <option value="<%= c.id %>" <%= g.welcomeChannel === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label>歡迎訊息</label>
              <textarea name="message" placeholder="例如：歡迎 {user} 來到 {server}！"><%= g.welcomeMessage || '' %></textarea>
              <div class="hint">可用變數: <code>{user}</code> 成員名稱, <code>{server}</code> 伺服器名稱</div>
            </div>
            <div class="form-group checkbox">
              <input type="checkbox" name="enabled" value="1" <%= g.welcomeEnabled ? 'checked' : '' %>>
              <label>啟用歡迎訊息</label>
            </div>
            <button type="submit" class="btn">儲存</button>
            <span id="msg-<%= g.id %>" class="success"></span>
          </form>
        </div>

        <div class="card">
          <h2>👋 告別訊息設定 — <%= g.name %></h2>
          <form method="POST" action="/api/settings/<%= g.id %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="type" value="farewell">
            <div class="form-group">
              <label>頻道</label>
              <select name="channelId">
                <option value="">不啟用</option>
                <% g.channels.forEach(c => { %>
                  <option value="<%= c.id %>" <%= g.farewellChannel === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label>告別訊息</label>
              <textarea name="message" placeholder="例如：{user} 離開了 {server}"><%= g.farewellMessage || '' %></textarea>
              <div class="hint">可用變數: <code>{user}</code> 成員名稱, <code>{server}</code> 伺服器名稱</div>
            </div>
            <div class="form-group checkbox">
              <input type="checkbox" name="enabled" value="1" <%= g.farewellEnabled ? 'checked' : '' %>>
              <label>啟用告別訊息</label>
            </div>
            <button type="submit" class="btn">儲存</button>
            <span id="msg-<%= g.id %>" class="success"></span>
          </form>
        </div>

        <div class="card">
          <h2>🎭 自助領取身分組 — <%= g.name %></h2>
          <p style="font-size:13px;color:#888;margin-bottom:12px;">勾選以下身分組，讓成員可以用 <code>/role add</code> 和 <code>/role remove</code> 自行領取或移除</p>
          <form method="POST" action="/api/settings/<%= g.id %>/roles">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:6px;max-height:300px;overflow-y:auto;background:#1e1e3a;padding:10px;border-radius:8px;margin-bottom:12px;">
              <% g.allRoles.forEach(r => { %>
                <label style="display:flex;align-items:center;gap:8px;padding:4px 6px;border-radius:4px;cursor:pointer;font-size:13px;">
                  <input type="checkbox" name="roles" value="<%= r.id %>" <%= g.selfRoles.includes(r.id) ? 'checked' : '' %>>
                  <span style="display:inline-block;width:12px;height:12px;border-radius:3px;background:<%= r.color %>;"></span>
                  <%= r.name %>
                </label>
              <% }); %>
            </div>
            <button type="submit" class="btn">儲存身分組設定</button>
          </form>
        </div>
      </div>
    <% }); %>
  </div>
  <script>
    function switchGuild(i) {
      document.querySelectorAll('.guild-tab').forEach((t, idx) => t.classList.toggle('active', idx === i));
      document.querySelectorAll('.guild-info').forEach((g, idx) => g.classList.toggle('active', idx === i));
    }
  </script>
</body>
</html>
