<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - OmniBot</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0f0f1a; color: #e0e0e0; display: flex; min-height: 100vh; }
    .sidebar { width: 200px; background: #16162a; padding: 24px 14px; display: flex; flex-direction: column; border-right: 1px solid #232340; }
    .sidebar .logo { font-size: 20px; font-weight: 800; margin-bottom: 28px; color: #fff; }
    .sidebar .logo span { color: #7c6ff0; }
    .sidebar nav a { display: block; padding: 8px 12px; color: #8888aa; text-decoration: none; border-radius: 8px; margin-bottom: 2px; font-size: 13px; }
    .sidebar nav a:hover { background: #1e1e3a; color: #fff; }
    .sidebar nav a.active { background: #2a2a4a; color: #fff; }
    .sidebar .logout { margin-top: auto; color: #666; text-decoration: none; padding: 8px 12px; font-size: 12px; }
    .main { flex: 1; padding: 28px 36px; }
    h1 { font-size: 24px; margin-bottom: 20px; color: #fff; }
    .back { color: #7c6ff0; text-decoration: none; font-size: 14px; display: inline-block; margin-bottom: 16px; }
    .info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 14px; margin-bottom: 24px; }
    .info-card { background: #16162a; padding: 16px; border-radius: 10px; border: 1px solid #232340; }
    .info-card .label { font-size: 11px; color: #6666aa; text-transform: uppercase; }
    .info-card .value { font-size: 16px; font-weight: 600; color: #fff; margin-top: 4px; }
    .card { background: #16162a; border-radius: 12px; border: 1px solid #232340; padding: 20px; margin-bottom: 20px; }
    .card h2 { font-size: 16px; color: #fff; margin-bottom: 12px; }
    .channel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 6px; }
    .channel-item { background: #1e1e3a; padding: 8px 12px; border-radius: 6px; font-size: 13px; color: #aaa; }
    .say-form { margin-top: 12px; }
    .say-form select, .say-form input { width: 100%; padding: 8px 12px; background: #1e1e3a; border: 1px solid #333; border-radius: 6px; color: #fff; font-size: 13px; margin-bottom: 8px; }
    .say-form button { background: #7c6ff0; color: #fff; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; }
    .say-form button:hover { background: #6a5de0; }
    .say-form .status { margin-top: 8px; font-size: 13px; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="logo">Omni<span>Bot</span></div>
    <nav>
      <a href="/dashboard">儀表板</a>
      <a href="/logs">📋 日誌</a>
      <a href="/cmd">⚡ 指令</a>
    </nav>
    <a href="/logout" class="logout">登出</a>
  </aside>
  <div class="main">
    <a href="/dashboard" class="back">← 返回儀表板</a>
    <h1>🖥️ <%= guild.name %></h1>

    <div class="info-grid">
      <div class="info-card"><div class="label">ID</div><div class="value"><%= guild.id %></div></div>
      <div class="info-card"><div class="label">成員數</div><div class="value"><%= guild.memberCount %></div></div>
      <div class="info-card"><div class="label">擁有者</div><div class="value"><%= guild.ownerTag %></div></div>
      <div class="info-card"><div class="label">建立時間</div><div class="value"><%= guild.createdAt %></div></div>
    </div>

    <div class="card">
      <h2>📢 發送訊息到頻道</h2>
      <form class="say-form" onsubmit="sendMessage(event)">
        <select name="channelId" required>
          <option value="">選擇頻道...</option>
          <% guild.channels.forEach(c => { %>
            <option value="<%= c.id %>">#<%= c.name %></option>
          <% }); %>
        </select>
        <input type="text" name="message" placeholder="輸入訊息內容..." required>
        <button type="submit">發送</button>
        <div class="status" id="status"></div>
      </form>
    </div>

    <div class="card">
      <h2>📁 頻道列表 (<%= guild.channels.length %>)</h2>
      <div class="channel-grid">
        <% guild.channels.forEach(c => { %>
          <div class="channel-item">#<%= c.name %></div>
        <% }); %>
      </div>
    </div>
  </div>
  <script>
    async function sendMessage(e) {
      e.preventDefault();
      const form = e.target;
      const status = document.getElementById('status');
      status.textContent = '發送中...';
      status.style.color = '#aaa';
      const res = await fetch('/api/guild/' + '<%= guild.id %>' + '/say', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId: form.channelId.value, message: form.message.value }),
      });
      const data = await res.json();
      status.textContent = data.success ? '✅ 已發送' : '❌ 發送失敗: ' + data.error;
      status.style.color = data.success ? '#4ade80' : '#ef4444';
      if (data.success) form.message.value = '';
    }
  </script>
</body>
</html>
