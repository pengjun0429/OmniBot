# Discord Bot Token（必要）
DISCORD_TOKEN=你的_BOT_TOKEN

# Discord Client ID（必要）
DISCORD_CLIENT_ID=你的_CLIENT_ID

# Discord OAuth2（後臺 Discord 登入，必要）
DISCORD_CLIENT_SECRET=你的_CLIENT_SECRET
DISCORD_REDIRECT_URI=https://你的網域/auth/discord/callback

# Discord 測試伺服器 ID（選填，設了指令即時生效）
DISCORD_GUILD_ID=

# Google Sheets 資料庫（選填，不設則用本地 JSON）
GOOGLE_DB_URL=

# Gemini AI 客服（選填）
GEMINI_API_KEY=

# 氣象局 API Key（選填，用於 /earthquake）
CWA_API_KEY=

# YouTube API Key（選填，用於 /play 搜尋）
YOUTUBE_API_KEY=
