# Discord Bot Token
DISCORD_TOKEN=你的_BOT_TOKEN

# Discord Client ID
DISCORD_CLIENT_ID=你的_CLIENT_ID

# Discord OAuth2（用於後臺 Discord 登入）
DISCORD_CLIENT_SECRET=你的_CLIENT_SECRET
DISCORD_REDIRECT_URI=https://omnibot-yzti.onrender.com/auth/discord/callback

# 後臺管理員身分組 ID（Discord 登入時檢查，逗號分隔多個）
ADMIN_TOP_ROLE_IDS=可愛的管管們ID
ADMIN_MOD_ROLE_IDS=可惡的管管們ID

# Discord 測試伺服器 ID（設定後指令會立即註冊到該伺服器，不設則為全域需等 1 小時）
DISCORD_GUILD_ID=

# 管理員後臺
ADMIN_PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Google Sheets 資料庫（選填，不設則用本地 JSON）
GOOGLE_DB_URL=你的_AppsScript_部署網址

# 天氣功能（選填）
WEATHER_API_KEY=你的_WEATHER_API_KEY

# 歡迎/告別頻道 ID（選填，不填則不發送）
WELCOME_CHANNEL_ID=
FAREWELL_CHANNEL_ID=
