# Discord Bot Token（從 https://discord.com/developers/applications 取得）
DISCORD_TOKEN=你的_BOT_TOKEN

# Discord Client ID（Bot 的 Application ID）
DISCORD_CLIENT_ID=你的_CLIENT_ID

# Firebase 服務帳號金鑰路徑（相對於專案根目錄）
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Firebase 資料庫 URL（如果使用 Realtime Database，非必填）
FIREBASE_DATABASE_URL=

# 管理員後臺設定
ADMIN_PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# OpenWeatherMap API Key（天氣功能）
WEATHER_API_KEY=你的_WEATHER_API_KEY
